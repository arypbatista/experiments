---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import type { ExperimentMeta } from '../../experiments/types';

const metaModules = import.meta.glob<{ default: ExperimentMeta }>('../../experiments/*/meta.ts', { eager: true });
const pageModules = import.meta.glob<{ default: unknown }>('../../experiments/*/index.astro');

export async function getStaticPaths() {
  const metas = import.meta.glob<{ default: ExperimentMeta }>('../../experiments/*/meta.ts', { eager: true });

  return Object.entries(metas)
    .filter(([, mod]) => !mod.default.hidden)
    .map(([path, mod]) => {
      const slug = path.split('/').at(-2)!;
      return { params: { slug }, props: { meta: mod.default } };
    });
}

const { slug } = Astro.params;
const { meta } = Astro.props as { meta: ExperimentMeta };

const pageKey = `../../experiments/${slug}/index.astro`;
const pageLoader = pageModules[pageKey];
const Page = pageLoader ? ((await pageLoader()).default as any) : null;
---

{Page ? (
  <ExperimentLayout title={meta.title} tags={meta.tags} notes={meta.notes} mobileNotes={meta.mobileNotes}>
    <Page />
  </ExperimentLayout>
) : (
  <html>
    <head><title>Error — {slug}</title></head>
    <body style="background:#000;color:#fff;font-family:monospace;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;flex-direction:column;gap:12px;">
      <div style="font-size:14px;color:rgba(255,255,255,0.4);">experiment not found</div>
      <div style="font-size:20px;">{slug}</div>
      <div style="font-size:12px;color:rgba(255,255,255,0.3);">index.astro is missing</div>
      <a href="/" style="margin-top:16px;font-size:12px;color:rgba(255,255,255,0.5);text-decoration:none;border-bottom:1px solid rgba(255,255,255,0.2);">← back</a>
    </body>
  </html>
)}
