---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import type { ExperimentMeta } from '../../experiments/types';

const metaModules = import.meta.glob<{ default: ExperimentMeta }>('../../experiments/*/meta.ts', { eager: true });
const pageModules = import.meta.glob<{ default: unknown }>('../../experiments/*/index.astro');

export async function getStaticPaths() {
  const metas = import.meta.glob<{ default: ExperimentMeta }>('../../experiments/*/meta.ts', { eager: true });

  return Object.entries(metas).map(([path, mod]) => {
    const slug = path.split('/').at(-2)!;
    return { params: { slug }, props: { meta: mod.default } };
  });
}

const { slug } = Astro.params;
const { meta } = Astro.props as { meta: ExperimentMeta };

const pageKey = `../../experiments/${slug}/index.astro`;
const Page = (await pageModules[pageKey]()).default as any;
---

<ExperimentLayout title={meta.title} tags={meta.tags}>
  <Page />
</ExperimentLayout>
