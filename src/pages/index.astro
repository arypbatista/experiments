---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import type { ExperimentMeta, ExperimentEntry } from '../experiments/types';

const metaModules = import.meta.glob<{ default: ExperimentMeta }>('../experiments/*/meta.ts', { eager: true });

const experiments: ExperimentEntry[] = Object.entries(metaModules).map(([path, mod]) => ({
  slug: path.split('/').at(-2)!,
  ...mod.default,
}));

const allTags = [...new Set(experiments.flatMap(e => e.tags))].sort();
---

<BaseLayout>
  <div id="layout">
    <Sidebar tags={allTags} />

    <main id="main">
      <div id="grid">
        {experiments.map(experiment => (
          <ExperimentCard experiment={experiment} />
        ))}
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  #layout {
    display: flex;
    height: 100vh;
    background: #111;
  }

  #main {
    margin-left: var(--sidebar-width);
    flex: 1;
    overflow-y: auto;
    height: 100vh;
  }

  #grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2px;
    padding: 2px;
  }
</style>

<script>
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const cards = document.querySelectorAll<HTMLElement>('.experiment-card');

  let activeTags = new Set<string>();

  tagButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;

      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove('active');
      } else {
        activeTags.add(tag);
        btn.classList.add('active');
      }

      cards.forEach(card => {
        const cardTags = (card.dataset.tags ?? '').split(' ');
        const visible = activeTags.size === 0 || cardTags.some(t => activeTags.has(t));
        card.style.opacity = visible ? '1' : '0.1';
        card.style.pointerEvents = visible ? '' : 'none';
      });
    });
  });
</script>
