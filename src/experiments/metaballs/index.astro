<canvas id="canvas" style="display:block;width:100%;height:100%;"></canvas>

<script>
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // --- resize ---
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // --- grid resolution ---
  const CELL = 8;
  const THRESHOLD = 1.0;
  const RESTITUTION = 0.70;  // energy kept after wall bounce
  const DAMPING = 0.993;      // per-frame velocity decay
  const MAX_SPEED = 18;       // px/frame cap

  // --- blobs ---
  interface Blob {
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    hue: number;
  }

  function makeBlob(): Blob {
    const r = 80 + Math.random() * 60;
    return {
      x: r + Math.random() * (canvas.width  - r * 2),
      y: r + Math.random() * (canvas.height - r * 2),
      vx: (Math.random() - 0.5) * 2.5,
      vy: (Math.random() - 0.5) * 2.5,
      r,
      hue: Math.random() * 360,
    };
  }

  const blobs: Blob[] = Array.from({ length: 6 }, makeBlob);

  // --- drag state with velocity tracking ---
  let dragBlob: Blob | null = null;
  let dragOffX = 0, dragOffY = 0;
  let prevDragX = 0, prevDragY = 0, prevDragT = 0;
  let throwVx = 0, throwVy = 0;

  function nearestBlob(x: number, y: number): Blob | null {
    let best: Blob | null = null;
    let bestD = Infinity;
    for (const b of blobs) {
      const d = Math.hypot(b.x - x, b.y - y);
      if (d < b.r * 0.8 && d < bestD) { bestD = d; best = b; }
    }
    return best;
  }

  canvas.addEventListener('pointerdown', (e) => {
    const x = e.clientX, y = e.clientY;
    const hit = nearestBlob(x, y);
    if (hit) {
      dragBlob = hit;
      dragOffX = hit.x - x;
      dragOffY = hit.y - y;
      throwVx = 0; throwVy = 0;
      prevDragX = x; prevDragY = y; prevDragT = performance.now();
    } else {
      const b = makeBlob();
      b.x = x; b.y = y;
      b.vx = (Math.random() - 0.5) * 2.5;
      b.vy = (Math.random() - 0.5) * 2.5;
      blobs.push(b);
    }
  });

  canvas.addEventListener('pointermove', (e) => {
    if (!dragBlob) return;
    dragBlob.x = e.clientX + dragOffX;
    dragBlob.y = e.clientY + dragOffY;
    const now = performance.now();
    const dt = now - prevDragT;
    if (dt > 0) {
      // scale to ~16 ms frame units for consistent feel at any framerate
      throwVx = (e.clientX - prevDragX) / dt * 16;
      throwVy = (e.clientY - prevDragY) / dt * 16;
    }
    prevDragX = e.clientX; prevDragY = e.clientY; prevDragT = now;
  });

  canvas.addEventListener('pointerup', () => {
    if (dragBlob) {
      // clamp throw so it doesn't rocket off screen
      const spd = Math.hypot(throwVx, throwVy);
      if (spd > MAX_SPEED) { throwVx *= MAX_SPEED / spd; throwVy *= MAX_SPEED / spd; }
      dragBlob.vx = throwVx;
      dragBlob.vy = throwVy;
    }
    dragBlob = null;
  });
  canvas.addEventListener('pointercancel', () => { dragBlob = null; });

  // --- marching squares edge table ---
  // Each cell has 4 corners (TL, TR, BR, BL). Index 0..15.
  // We return line segment(s) as pairs of lerp'd edge points.
  // Edges: 0=top, 1=right, 2=bottom, 3=left
  const MS_EDGES: [number, number][][] = [
    [],              // 0000
    [[3, 2]],        // 0001 BL
    [[2, 1]],        // 0010 BR
    [[3, 1]],        // 0011 BL+BR
    [[1, 0]],        // 0100 TR
    [[3, 0], [1, 2]],// 0101 saddle
    [[2, 0]],        // 0110 TR+BR
    [[3, 0]],        // 0111 BL+BR+TR
    [[0, 3]],        // 1000 TL
    [[0, 2]],        // 1001 TL+BL
    [[0, 1], [2, 3]],// 1010 saddle
    [[0, 1]],        // 1011 TL+BL+BR — wait, recompute below
    [[1, 3]],        // 1100 TL+TR
    [[1, 2]],        // 1101 TL+TR+BL
    [[2, 3]],        // 1110 TL+TR+BR
    [],              // 1111
  ];
  // Fix cases 11 and 13 (missed in above shorthand)
  MS_EDGES[11] = [[0, 1]];  // TL+BL+BR: segment top→right
  MS_EDGES[13] = [[1, 2]];  // TL+TR+BL: segment right→bottom

  // For each edge index return the two corner indices it connects
  // Corners: 0=TL,1=TR,2=BR,3=BL  (row-major, y-down)
  const EDGE_CORNERS: [number, number][] = [
    [0, 1], // top:   TL–TR
    [1, 2], // right: TR–BR
    [2, 3], // bot:   BR–BL
    [3, 0], // left:  BL–TL
  ];

  // Corner offsets [dx, dy] within a cell
  const CORNER_OFFSET: [number, number][] = [
    [0, 0], // TL
    [1, 0], // TR
    [1, 1], // BR
    [0, 1], // BL
  ];

  // --- scalar field ---
  // Each blob also has 4 mirror ghosts reflected across each wall.
  // Their contribution makes the iso-surface stretch toward the wall —
  // the "water sticking to glass" meniscus effect.
  const WALL_GHOST_STRENGTH = 0.55; // fraction of real blob strength for ghosts
  const WALL_ATTRACT_DIST = 160;    // only mirror when center is within this distance

  function field(px: number, py: number): number {
    const W = canvas.width, H = canvas.height;
    let sum = 0;
    for (const b of blobs) {
      // real blob
      const dx = px - b.x, dy = py - b.y;
      const d2 = dx * dx + dy * dy;
      sum += d2 < 1e-4 ? 4 : (b.r * b.r) / d2;

      // mirror ghosts — only active when blob is near a wall
      const str = b.r * b.r * WALL_GHOST_STRENGTH;
      function ghost(gx: number, gy: number) {
        const ddx = px - gx, ddy = py - gy;
        const gd2 = ddx * ddx + ddy * ddy;
        sum += gd2 < 1e-4 ? 4 * WALL_GHOST_STRENGTH : str / gd2;
      }
      if (b.x < WALL_ATTRACT_DIST)     ghost(-b.x, b.y);
      if (b.x > W - WALL_ATTRACT_DIST) ghost(2 * W - b.x, b.y);
      if (b.y < WALL_ATTRACT_DIST)     ghost(b.x, -b.y);
      if (b.y > H - WALL_ATTRACT_DIST) ghost(b.x, 2 * H - b.y);
    }
    return sum;
  }

  // Dominant hue at a point (weighted by each blob's contribution)
  function dominantHue(px: number, py: number): number {
    let wx = 0, wy = 0, total = 0;
    for (const b of blobs) {
      const dx = px - b.x, dy = py - b.y;
      const d2 = Math.max(dx * dx + dy * dy, 1e-4);
      const w = (b.r * b.r) / d2;
      const rad = (b.hue * Math.PI) / 180;
      wx += Math.cos(rad) * w;
      wy += Math.sin(rad) * w;
      total += w;
    }
    if (total === 0) return 0;
    return ((Math.atan2(wy / total, wx / total) * 180) / Math.PI + 360) % 360;
  }

  // --- render ---
  let t = 0;

  function draw() {
    t++;
    const W = canvas.width;
    const H = canvas.height;

    // move blobs (physics)
    for (const b of blobs) {
      if (b === dragBlob) continue;

      b.vx *= DAMPING;
      b.vy *= DAMPING;

      // cap speed
      const spd = Math.hypot(b.vx, b.vy);
      if (spd > MAX_SPEED) { b.vx *= MAX_SPEED / spd; b.vy *= MAX_SPEED / spd; }

      b.x += b.vx;
      b.y += b.vy;

      // bounce off walls with restitution
      if (b.x < 0)     { b.x = 0;  b.vx =  Math.abs(b.vx) * RESTITUTION; }
      if (b.x > W)     { b.x = W;  b.vx = -Math.abs(b.vx) * RESTITUTION; }
      if (b.y < 0)     { b.y = 0;  b.vy =  Math.abs(b.vy) * RESTITUTION; }
      if (b.y > H)     { b.y = H;  b.vy = -Math.abs(b.vy) * RESTITUTION; }

      b.hue = (b.hue + 0.15) % 360;
    }

    // clear
    ctx.fillStyle = '#0a0a0f';
    ctx.fillRect(0, 0, W, H);

    const cols = Math.ceil(W / CELL) + 1;
    const rows = Math.ceil(H / CELL) + 1;

    // pre-sample scalar field on grid
    const grid = new Float32Array(cols * rows);
    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        grid[row * cols + col] = field(col * CELL, row * CELL);
      }
    }

    // collect all iso-contour segments
    type Seg = { x1: number; y1: number; x2: number; y2: number; hue: number };
    const segs: Seg[] = [];

    for (let row = 0; row < rows - 1; row++) {
      for (let col = 0; col < cols - 1; col++) {
        const x0 = col * CELL;
        const y0 = row * CELL;

        // corner values
        const cv: number[] = [
          grid[row * cols + col],         // TL
          grid[row * cols + col + 1],     // TR
          grid[(row + 1) * cols + col + 1], // BR
          grid[(row + 1) * cols + col],   // BL
        ];

        // build index
        let idx = 0;
        if (cv[0] >= THRESHOLD) idx |= 8;
        if (cv[1] >= THRESHOLD) idx |= 4;
        if (cv[2] >= THRESHOLD) idx |= 2;
        if (cv[3] >= THRESHOLD) idx |= 1;

        const edges = MS_EDGES[idx];
        if (!edges.length) continue;

        // lerp edge intersection
        function edgePt(edgeIdx: number): [number, number] {
          const [ca, cb] = EDGE_CORNERS[edgeIdx];
          const [dxa, dya] = CORNER_OFFSET[ca];
          const [dxb, dyb] = CORNER_OFFSET[cb];
          const va = cv[ca], vb = cv[cb];
          const t = (va === vb) ? 0.5 : (THRESHOLD - va) / (vb - va);
          return [x0 + (dxa + (dxb - dxa) * t) * CELL,
                  y0 + (dya + (dyb - dya) * t) * CELL];
        }

        for (const [e0, e1] of edges) {
          const [x1, y1] = edgePt(e0);
          const [x2, y2] = edgePt(e1);
          const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
          segs.push({ x1, y1, x2, y2, hue: dominantHue(mx, my) });
        }
      }
    }

    // draw filled blob interior using OffscreenCanvas flood-like approach:
    // scan each cell for fully-inside corners and fill them
    for (let row = 0; row < rows - 1; row++) {
      for (let col = 0; col < cols - 1; col++) {
        const cv0 = grid[row * cols + col];
        const cv1 = grid[row * cols + col + 1];
        const cv2 = grid[(row + 1) * cols + col + 1];
        const cv3 = grid[(row + 1) * cols + col];
        const inside = (cv0 >= THRESHOLD ? 1 : 0)
                     + (cv1 >= THRESHOLD ? 1 : 0)
                     + (cv2 >= THRESHOLD ? 1 : 0)
                     + (cv3 >= THRESHOLD ? 1 : 0);
        if (inside === 0) continue;

        const cx = col * CELL + CELL / 2;
        const cy = row * CELL + CELL / 2;
        const hue = dominantHue(cx, cy);
        const alpha = Math.min(1, (inside / 4) * 1.5);
        ctx.fillStyle = `hsla(${hue},70%,55%,${alpha})`;
        ctx.fillRect(col * CELL, row * CELL, CELL, CELL);
      }
    }

    // draw iso-contour lines (bright edge)
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    for (const s of segs) {
      ctx.strokeStyle = `hsl(${s.hue},90%,80%)`;
      ctx.beginPath();
      ctx.moveTo(s.x1, s.y1);
      ctx.lineTo(s.x2, s.y2);
      ctx.stroke();
    }

    requestAnimationFrame(draw);
  }

  draw();
</script>
