---
// No layout — ExperimentLayout applied by [slug].astro
---

<canvas id="canvas" style="display:block;width:100%;height:100%;"></canvas>
<div style="position:fixed;bottom:24px;right:24px;display:flex;gap:8px;">
  <button
    id="launch-btn"
    style="background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:12px;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;"
    >LAUNCH [L]</button
  >
  <button
    id="burn-btn"
    style="background:transparent;border:1px solid rgba(255,255,0,0.5);color:rgba(255,255,0,0.8);font-family:monospace;font-size:12px;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;"
    >BURN [B]</button
  >
  <button
    id="crash-btn"
    style="background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:12px;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;"
    >CRASH [C]</button
  >
</div>

<div
  id="launch-controls"
  style="position:fixed;top:64px;right:24px;font-family:monospace;font-size:11px;color:rgba(255,255,255,0.7);display:flex;flex-direction:column;gap:8px;min-width:200px;"
>
  <div style="display:flex;flex-direction:column;gap:2px;margin-bottom:2px;">
    <span
      style="font-size:12px;color:rgba(255,255,255,0.9);letter-spacing:0.06em;"
      >AUTO-LAUNCH</span
    >
    <span style="font-size:10px;color:rgba(255,255,255,0.4);line-height:1.4;"
      >parameters used each time<br />the ship relaunches automatically</span
    >
  </div>
  <select
    id="preset-select"
    style="background:#000;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.8);font-family:monospace;font-size:11px;padding:4px 6px;cursor:pointer;width:100%;"
  >
    <option value="low-orbit">Earth low orbit</option>
    <option value="high-orbit">Earth high orbit</option>
    <option value="moon-orbit" selected>Moon orbit</option>
    <option value="custom">Custom</option>
  </select>
  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="impulse-label">impulse: 1.05</span>
    <input
      id="impulse-range"
      type="range"
      min="0.8"
      max="1.5"
      step="0.01"
      value="1.05"
      style="accent-color:white;width:100%;"
    />
  </label>
  <label id="moon-angle-row" style="display:flex;flex-direction:column;gap:3px;">
    <span id="angle-label">moon angle offset: 0.12 rad</span>
    <input
      id="angle-range"
      type="range"
      min="-0.5"
      max="0.5"
      step="0.01"
      value="0.12"
      style="accent-color:white;width:100%;"
    />
  </label>
  <label id="launch-angle-row" style="display:none;flex-direction:column;gap:3px;">
    <span id="launch-angle-label">launch angle: 0°</span>
    <input
      id="launch-angle-range"
      type="range"
      min="0"
      max="360"
      step="1"
      value="0"
      style="accent-color:white;width:100%;"
    />
  </label>
</div>

<script>
  import * as THREE from "three";

  // ── Renderer & camera ──────────────────────────────────────────────────────
  const canvas = document.getElementById("canvas") as HTMLCanvasElement;
  let W = window.innerWidth,
    H = window.innerHeight;

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setSize(W, H);
  renderer.setClearColor(0x000000, 1);

  const scene = new THREE.Scene();
  const camera = new THREE.OrthographicCamera(
    -W / 2,
    W / 2,
    H / 2,
    -H / 2,
    0.1,
    10,
  );
  camera.position.z = 1;

  window.addEventListener("resize", () => {
    W = window.innerWidth;
    H = window.innerHeight;
    renderer.setSize(W, H);
    camera.left = -W / 2;
    camera.right = W / 2;
    camera.top = H / 2;
    camera.bottom = -H / 2;
    camera.updateProjectionMatrix();
  });

  // ── Geometry helpers ───────────────────────────────────────────────────────

  function makeCircleLine(r: number, segs = 64): THREE.Line {
    const pts: THREE.Vector3[] = [];
    for (let i = 0; i <= segs; i++) {
      const a = (i / segs) * Math.PI * 2;
      pts.push(new THREE.Vector3(Math.cos(a) * r, Math.sin(a) * r, 0));
    }
    return new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(pts),
      new THREE.LineBasicMaterial({ color: 0xffffff }),
    );
  }

  function makeDashedCircle(r: number, segs = 128): THREE.Line {
    const pts: THREE.Vector3[] = [];
    for (let i = 0; i <= segs; i++) {
      const a = (i / segs) * Math.PI * 2;
      pts.push(new THREE.Vector3(Math.cos(a) * r, Math.sin(a) * r, 0));
    }
    const line = new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(pts),
      new THREE.LineDashedMaterial({
        color: 0xffffff,
        dashSize: 12,
        gapSize: 7,
      }),
    );
    line.computeLineDistances();
    return line;
  }

  function makeShipSquare(): THREE.LineSegments {
    // Geometry pre-rotated -45° so heading=0 means facing right with a flat edge forward.
    // Forward corner is at (+r, 0); tail extends backward along -x axis.
    const r = 5 * Math.SQRT2; // circumradius: keeps same visual size as the original ±5 square
    const pts = new Float32Array([
      r,
      0,
      0,
      0,
      -r,
      0, // right–bottom edge
      0,
      -r,
      0,
      -r,
      0,
      0, // bottom–left edge
      -r,
      0,
      0,
      0,
      r,
      0, // left–top edge
      0,
      r,
      0,
      r,
      0,
      0, // top–right edge
      0,
      0,
      0,
      -r * 1.6,
      0,
      0, // tail: center → backward (-x)
    ]);
    const geo = new THREE.BufferGeometry();
    geo.setAttribute("position", new THREE.BufferAttribute(pts, 3));
    return new THREE.LineSegments(
      geo,
      new THREE.LineBasicMaterial({ color: 0xffffff }),
    );
  }

  // ── Physics constants ──────────────────────────────────────────────────────

  const G = 1;
  const M_EARTH = 1_500_000;
  // Moon mass is weaker — same gravity formula as Earth, just smaller mass.
  // Increase to make Moon pull stronger; decrease to make it barely felt.
  const M_MOON = 350_000;
  const R_EARTH = 25;
  const R_MOON = 12;
  const MOON_ORBIT_R = 250;
  const MOON_OMEGA = Math.sqrt((G * M_EARTH) / MOON_ORBIT_R ** 3);
  const A_XFER = (R_EARTH + MOON_ORBIT_R) / 2;
  const T_XFER_HALF = Math.PI * Math.sqrt(A_XFER ** 3 / (G * M_EARTH));
  const V_LAUNCH_BASE = Math.sqrt(G * M_EARTH * (2 / R_EARTH - 1 / A_XFER));
  const MOON_START = Math.PI - MOON_OMEGA * T_XFER_HALF + 0.15;
  const SLING_SCALE = 3.3; // px drag → px/s velocity

  // ── Tunable auto-launch parameters ────────────────────────────────────────
  let launchImpulse = 1.05;      // multiplier on V_LAUNCH_BASE
  let launchAngleOffset = 0.12;  // rad ahead of predicted Moon position (moon-orbit only)
  let launchAngleDeg = 0;        // fixed launch angle in degrees (non-moon presets)

  // ── Static scene objects ───────────────────────────────────────────────────

  scene.add(makeCircleLine(R_EARTH));
  const moonOrbitRing = makeDashedCircle(MOON_ORBIT_R);
  scene.add(moonOrbitRing);
  const moonMesh = makeCircleLine(R_MOON);
  scene.add(moonMesh);

  // ── Ship pool ──────────────────────────────────────────────────────────────

  interface Ship {
    sx: number;
    sy: number;
    svx: number;
    svy: number;
    heading: number; // facing angle (rad) — independent of velocity
    crashed: boolean;
    crashTimer: number;
    auto: boolean; // auto-ship restarts; user ships are removed
    mesh: THREE.Line;
  }

  const ships: Ship[] = [];

  function spawnShip(
    sx: number,
    sy: number,
    svx: number,
    svy: number,
    auto = false,
  ): Ship {
    const mesh = makeShipSquare();
    scene.add(mesh);
    const ship: Ship = {
      sx,
      sy,
      svx,
      svy,
      heading: Math.atan2(svy, svx),
      crashed: false,
      crashTimer: 0,
      auto,
      mesh,
    };
    ships.push(ship);
    return ship;
  }

  function removeShip(ship: Ship) {
    scene.remove(ship.mesh);
    ship.mesh.geometry.dispose();
  }

  // ── Burn particles ─────────────────────────────────────────────────────────

  interface Particle {
    life: number; // 1 → 0
    mesh: THREE.Line;
  }
  const particles: Particle[] = [];

  function spawnBurnParticle(x: number, y: number) {
    const s = 3;
    const geo = new THREE.BufferGeometry().setFromPoints([
      new THREE.Vector3(-s, -s, 0),
      new THREE.Vector3(s, -s, 0),
      new THREE.Vector3(s, s, 0),
      new THREE.Vector3(-s, s, 0),
      new THREE.Vector3(-s, -s, 0),
    ]);
    const mat = new THREE.LineBasicMaterial({
      color: 0xffff00,
      transparent: true,
      opacity: 1,
    });
    const mesh = new THREE.Line(geo, mat);
    mesh.position.set(x, y, 0);
    scene.add(mesh);
    particles.push({ life: 1, mesh });
  }

  function updateParticles(dt: number) {
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.life -= dt * 3; // fades in ~0.33 s
      if (p.life <= 0) {
        scene.remove(p.mesh);
        p.mesh.geometry.dispose();
        particles.splice(i, 1);
      } else {
        (p.mesh.material as THREE.LineBasicMaterial).opacity = p.life;
        const scale = 1 + (1 - p.life) * 2;
        p.mesh.scale.set(scale, scale, 1);
      }
    }
  }

  // Initial auto-launched ship
  spawnShip(R_EARTH, 0, 0, V_LAUNCH_BASE * launchImpulse, true);

  // ── Moon state ─────────────────────────────────────────────────────────────

  let moonAngle = MOON_START;
  let mx = Math.cos(moonAngle) * MOON_ORBIT_R;
  let my = Math.sin(moonAngle) * MOON_ORBIT_R;

  // ── Physics step ──────────────────────────────────────────────────────────

  function computeLaunchAngle(): number {
    if (presetSelect.value === 'moon-orbit') {
      return moonAngle + MOON_OMEGA * T_XFER_HALF + launchAngleOffset + Math.PI;
    }
    return launchAngleDeg * (Math.PI / 180);
  }

  function autoLaunch() {
    const la = computeLaunchAngle();
    const vl = V_LAUNCH_BASE * launchImpulse;
    spawnShip(
      Math.cos(la) * R_EARTH,
      Math.sin(la) * R_EARTH,
      -Math.sin(la) * vl,
       Math.cos(la) * vl,
    );
  }

  function stepShip(ship: Ship, dt: number) {
    if (ship.crashed) {
      ship.crashTimer -= dt;
      if (ship.crashTimer <= 0) {
        if (ship.auto) {
          // Wait until every other ship is gone before relaunching
          if (ships.some((s) => s !== ship && !s.crashed)) {
            ship.crashTimer = 0.5;
            return;
          }
          const la = computeLaunchAngle();
          ship.sx = Math.cos(la) * R_EARTH;
          ship.sy = Math.sin(la) * R_EARTH;
          const vl = V_LAUNCH_BASE * launchImpulse;
          ship.svx = -Math.sin(la) * vl;
          ship.svy =  Math.cos(la) * vl;
          ship.heading = Math.atan2(ship.svy, ship.svx);
          ship.crashed = false;
          ship.mesh.visible = true;
        } else {
          removeShip(ship);
          ships.splice(ships.indexOf(ship), 1);
        }
      }
      return;
    }

    // Pure Newtonian gravity — same formula for Earth and Moon, just different masses.
    // F = G*M/r² toward body  →  a = G*M*(body - ship) / r³
    const SUB = 8,
      sdt = dt / SUB;
    for (let i = 0; i < SUB; i++) {
      const re = Math.hypot(ship.sx, ship.sy);
      const axe = (G * M_EARTH * -ship.sx) / (re * re * re);
      const aye = (G * M_EARTH * -ship.sy) / (re * re * re);

      const dxm = mx - ship.sx,
        dym = my - ship.sy;
      const rm = Math.hypot(dxm, dym);
      const axm = (G * M_MOON * dxm) / (rm * rm * rm);
      const aym = (G * M_MOON * dym) / (rm * rm * rm);

      ship.svx += (axe + axm) * sdt;
      ship.svy += (aye + aym) * sdt;
      ship.sx += ship.svx * sdt;
      ship.sy += ship.svy * sdt;
    }

    const re = Math.hypot(ship.sx, ship.sy);
    const rm = Math.hypot(mx - ship.sx, my - ship.sy);

    const offScreen = Math.abs(ship.sx) > W / 2 || Math.abs(ship.sy) > H / 2;
    if (re < R_EARTH || rm < R_MOON || offScreen) {
      ship.crashed = true;
      ship.crashTimer = 1.5;
      ship.mesh.visible = false;
    }
  }

  function updateShipMesh(ship: Ship) {
    if (ship.mesh.visible) {
      ship.mesh.position.set(ship.sx, ship.sy, 0);
      ship.mesh.rotation.z = ship.heading;
    }
  }

  // ── Slingshot input ────────────────────────────────────────────────────────

  // Convert canvas mouse coords to scene coords (Y is flipped)
  function toScene(cx: number, cy: number) {
    return { x: cx - W / 2, y: H / 2 - cy };
  }

  let dragging = false;
  let dragA = { x: 0, y: 0 }; // scene-space start (ship spawn point)
  let dragB = { x: 0, y: 0 }; // scene-space current mouse

  // Slingshot line: from drag start to current mouse
  const slingshotBuf = new Float32Array(6);
  const slingshotGeo = new THREE.BufferGeometry();
  slingshotGeo.setAttribute(
    "position",
    new THREE.BufferAttribute(slingshotBuf, 3),
  );
  const slingshotLine = new THREE.Line(
    slingshotGeo,
    new THREE.LineDashedMaterial({
      color: 0xffffff,
      dashSize: 6,
      gapSize: 4,
      opacity: 0.6,
      transparent: true,
    }),
  );
  slingshotLine.visible = false;
  scene.add(slingshotLine);

  // Small crosshair at drag origin
  const markerGeo = new THREE.BufferGeometry().setFromPoints([
    new THREE.Vector3(-6, 0, 0),
    new THREE.Vector3(6, 0, 0),
    new THREE.Vector3(0, -6, 0),
    new THREE.Vector3(0, 6, 0),
  ]);
  const dragMarker = new THREE.LineSegments(
    markerGeo,
    new THREE.LineBasicMaterial({
      color: 0xffffff,
      opacity: 0.6,
      transparent: true,
    }),
  );
  dragMarker.visible = false;
  scene.add(dragMarker);

  function onDown(cx: number, cy: number) {
    dragging = true;
    dragA = toScene(cx, cy);
    dragB = { ...dragA };
    dragMarker.position.set(dragA.x, dragA.y, 0);
    dragMarker.visible = true;
  }
  function onMove(cx: number, cy: number) {
    if (!dragging) return;
    dragB = toScene(cx, cy);
    // Update slingshot line: from A to B
    slingshotBuf[0] = dragA.x;
    slingshotBuf[1] = dragA.y;
    slingshotBuf[2] = 0;
    slingshotBuf[3] = dragB.x;
    slingshotBuf[4] = dragB.y;
    slingshotBuf[5] = 0;
    slingshotGeo.attributes.position.needsUpdate = true;
    slingshotLine.computeLineDistances();
    slingshotLine.visible = true;
  }
  function onUp() {
    if (!dragging) return;
    dragging = false;
    slingshotLine.visible = false;
    dragMarker.visible = false;
    // Velocity is opposite of drag vector (slingshot: pull back → launch forward)
    const vx = (dragA.x - dragB.x) * SLING_SCALE;
    const vy = (dragA.y - dragB.y) * SLING_SCALE;
    spawnShip(dragA.x, dragA.y, vx, vy, false);
  }

  canvas.addEventListener("mousedown", (e) => onDown(e.clientX, e.clientY));
  canvas.addEventListener("mousemove", (e) => onMove(e.clientX, e.clientY));
  canvas.addEventListener("mouseup", () => onUp());
  canvas.addEventListener("mouseleave", () => onUp());

  canvas.addEventListener(
    "touchstart",
    (e) => {
      e.preventDefault();
      onDown(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchmove",
    (e) => {
      e.preventDefault();
      onMove(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchend",
    (e) => {
      e.preventDefault();
      onUp();
    },
    { passive: false },
  );

  // Crash one ship at a time, oldest first (FIFO)
  function crashOne() {
    for (const ship of ships) {
      if (!ship.crashed) {
        ship.crashed = true;
        ship.crashTimer = 1.5;
        ship.mesh.visible = false;
        return;
      }
    }
  }

  // Burn: thrust in current direction on the last spawned active ship
  function burn() {
    for (let i = ships.length - 1; i >= 0; i--) {
      const ship = ships[i];
      if (!ship.crashed) {
        const BURN = 50;
        ship.svx += Math.cos(ship.heading) * BURN;
        ship.svy += Math.sin(ship.heading) * BURN;
        const tailDist = 5 * Math.SQRT2 * 1.6;
        spawnBurnParticle(
          ship.sx - Math.cos(ship.heading) * tailDist,
          ship.sy - Math.sin(ship.heading) * tailDist,
        );
        return;
      }
    }
  }

  const presetSelect      = document.getElementById('preset-select')      as HTMLSelectElement;
  const impulseRange      = document.getElementById('impulse-range')      as HTMLInputElement;
  const impulseLabel      = document.getElementById('impulse-label')!;
  const angleRange        = document.getElementById('angle-range')        as HTMLInputElement;
  const angleLabel        = document.getElementById('angle-label')!;
  const moonAngleRow      = document.getElementById('moon-angle-row')!;
  const launchAngleRow    = document.getElementById('launch-angle-row')!;
  const launchAngleRange  = document.getElementById('launch-angle-range') as HTMLInputElement;
  const launchAngleLabel  = document.getElementById('launch-angle-label')!;

  // Presets: [impulse, moonAngleOffset, launchAngleDeg]
  const PRESETS: Record<string, [number, number, number]> = {
    'low-orbit':  [0.91,  0.0,  0],
    'high-orbit': [0.97,  0.0,  0],
    'moon-orbit': [1.05,  0.12, 0],
  };

  function updateAngleRowVisibility() {
    const isMoon = presetSelect.value === 'moon-orbit';
    moonAngleRow.style.display   = isMoon ? 'flex' : 'none';
    launchAngleRow.style.display = isMoon ? 'none' : 'flex';
  }

  function applyValues(impulse: number, moonOffset: number, launchDeg: number) {
    launchImpulse     = impulse;
    launchAngleOffset = moonOffset;
    launchAngleDeg    = launchDeg;
    impulseRange.value     = impulse.toFixed(2);
    angleRange.value       = moonOffset.toFixed(2);
    launchAngleRange.value = String(launchDeg);
    impulseLabel.textContent     = `impulse: ${impulse.toFixed(2)}`;
    angleLabel.textContent       = `moon angle offset: ${moonOffset.toFixed(2)} rad`;
    launchAngleLabel.textContent = `launch angle: ${launchDeg}°`;
    updateAngleRowVisibility();
  }

  presetSelect.addEventListener('change', () => {
    const preset = PRESETS[presetSelect.value];
    if (preset) applyValues(preset[0], preset[1], preset[2]);
    else updateAngleRowVisibility();
  });

  impulseRange.addEventListener('input', () => {
    launchImpulse = parseFloat(impulseRange.value);
    impulseLabel.textContent = `impulse: ${launchImpulse.toFixed(2)}`;
    presetSelect.value = 'custom';
  });

  angleRange.addEventListener('input', () => {
    launchAngleOffset = parseFloat(angleRange.value);
    angleLabel.textContent = `moon angle offset: ${launchAngleOffset.toFixed(2)} rad`;
    presetSelect.value = 'custom';
  });

  launchAngleRange.addEventListener('input', () => {
    launchAngleDeg = parseInt(launchAngleRange.value);
    launchAngleLabel.textContent = `launch angle: ${launchAngleDeg}°`;
    presetSelect.value = 'custom';
  });

  updateAngleRowVisibility();

  document.getElementById("launch-btn")!.addEventListener("click", autoLaunch);
  document.getElementById("burn-btn")!.addEventListener("click", burn);
  document.getElementById("crash-btn")!.addEventListener("click", crashOne);
  const keysHeld = new Set<string>();
  window.addEventListener("keydown", (e) => {
    keysHeld.add(e.key);
    if (e.key === "l" || e.key === "L") autoLaunch();
    if (e.key === "b" || e.key === "B") burn();
    if (e.key === "c" || e.key === "C") crashOne();
  });
  window.addEventListener("keyup", (e) => keysHeld.delete(e.key));

  const TURN_RATE = 2.5; // rad/s

  function steerLastShip(dt: number) {
    const left = keysHeld.has("a") || keysHeld.has("A");
    const right = keysHeld.has("d") || keysHeld.has("D");
    if (!left && !right) return;
    for (let i = ships.length - 1; i >= 0; i--) {
      const ship = ships[i];
      if (ship.crashed) continue;
      ship.heading += (left ? 1 : -1) * TURN_RATE * dt;
      return;
    }
  }

  // ── Animation loop ─────────────────────────────────────────────────────────

  let t0 = 0;
  function animate(t: number) {
    const dt = Math.min((t - t0) / 1000, 0.05);
    t0 = t;

    moonAngle += MOON_OMEGA * dt;
    mx = Math.cos(moonAngle) * MOON_ORBIT_R;
    my = Math.sin(moonAngle) * MOON_ORBIT_R;
    moonMesh.position.set(mx, my, 0);

    steerLastShip(dt);
    for (let i = ships.length - 1; i >= 0; i--) {
      stepShip(ships[i], dt);
      if (ships[i]) updateShipMesh(ships[i]);
    }
    updateParticles(dt);

    renderer.render(scene, camera);
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
