---
---

<canvas id="canvas" style="display:block;width:100%;height:100%;"></canvas>

<!-- Parameter panel — top-right -->
<div
  id="controls"
  style="position:fixed;top:64px;right:24px;font-family:monospace;font-size:11px;color:rgba(255,255,255,0.7);display:flex;flex-direction:column;gap:8px;min-width:200px;"
>
  <div style="display:flex;flex-direction:column;gap:2px;margin-bottom:2px;">
    <span style="font-size:12px;color:rgba(255,255,255,0.9);letter-spacing:0.06em;">CLOTH</span>
    <span style="font-size:10px;color:rgba(255,255,255,0.4);line-height:1.4;">drag to tear · W wind · R reset</span>
  </div>

  <select
    id="shape-select"
    style="background:#000;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.8);font-family:monospace;font-size:11px;padding:4px 6px;cursor:pointer;width:100%;"
  >
    <option value="curtain" selected>Curtain</option>
    <option value="full-curtain">Full curtain</option>
    <option value="flag">Flag</option>
    <option value="hammock">Hammock</option>
    <option value="banner">Banner</option>
    <option value="net">Net</option>
  </select>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="gravity-label">gravity: 0.45</span>
    <input id="gravity-range" type="range" min="0.05" max="1.5" step="0.01" value="0.45"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="damping-label">damping: 0.99</span>
    <input id="damping-range" type="range" min="0.90" max="0.999" step="0.001" value="0.99"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="stiffness-label">stiffness: 8</span>
    <input id="stiffness-range" type="range" min="1" max="20" step="1" value="8"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="wind-label">wind strength: 0.35</span>
    <input id="wind-range" type="range" min="0.05" max="1.5" step="0.01" value="0.35"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="tear-label">tear radius: 36</span>
    <input id="tear-range" type="range" min="5" max="100" step="1" value="36"
      style="accent-color:white;width:100%;" />
  </label>
</div>

<!-- Action buttons — bottom-right -->
<div style="position:fixed;bottom:24px;right:24px;display:flex;gap:8px;">
  <button
    id="wind-btn"
    style="background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:12px;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;"
  >WIND [W]</button>
  <button
    id="reset-btn"
    style="background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:12px;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;"
  >RESET [R]</button>
</div>

<script>
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // ── Tunable params (driven by sliders) ───────────────────────────────────────
  let GRAVITY     = 0.45;
  let DAMPING     = 0.99;
  let ITERATIONS  = 8;
  let WIND_FORCE  = 0.35;
  let TEAR_RADIUS = 36;

  const WIND_GUST_FREQ = 0.0012;

  // ── Shape configs ────────────────────────────────────────────────────────────
  type ShapeId = 'curtain' | 'full-curtain' | 'flag' | 'hammock' | 'banner' | 'net';

  interface ShapeDef {
    cols: number;
    rows: number;
    /** Returns true if the point at (row, col) should be pinned */
    pinned: (row: number, col: number, cols: number, rows: number) => boolean;
    /** Fraction of viewport width the cloth should span */
    widthFrac: number;
    /** Starting Y as fraction of viewport height */
    startYFrac: number;
  }

  const SHAPES: Record<ShapeId, ShapeDef> = {
    curtain: {
      cols: 45, rows: 28, widthFrac: 0.75, startYFrac: 0.08,
      pinned: (r, c, _C, _R) => r === 0 && c % 5 === 0,
    },
    'full-curtain': {
      cols: 45, rows: 28, widthFrac: 0.75, startYFrac: 0.08,
      pinned: (r, _c, _C, _R) => r === 0,
    },
    flag: {
      cols: 40, rows: 24, widthFrac: 0.55, startYFrac: 0.10,
      pinned: (r, c, _C, _R) => c === 0 && r % 3 === 0,
    },
    hammock: {
      cols: 40, rows: 20, widthFrac: 0.65, startYFrac: 0.15,
      pinned: (r, c, C, R) =>
        (r === 0 && c === 0) || (r === 0 && c === C - 1) ||
        (r === R - 1 && c === 0) || (r === R - 1 && c === C - 1),
    },
    banner: {
      cols: 50, rows: 14, widthFrac: 0.82, startYFrac: 0.08,
      pinned: (r, c, C, _R) => r === 0 && (c === 0 || c === C - 1),
    },
    net: {
      cols: 30, rows: 20, widthFrac: 0.55, startYFrac: 0.08,
      pinned: (r, c, C, _R) => r === 0 && c % 3 === 0,
    },
  };

  // ── State ────────────────────────────────────────────────────────────────────
  let W = window.innerWidth;
  let H = window.innerHeight;
  let windOn = false;
  let tick = 0;
  let currentShape: ShapeId = 'curtain';

  interface Point {
    x: number; y: number;
    px: number; py: number;
    pinned: boolean;
  }

  interface Constraint {
    a: Point; b: Point;
    len: number;
    active: boolean;
  }

  let points: Point[] = [];
  let constraints: Constraint[] = [];

  // ── Build cloth ──────────────────────────────────────────────────────────────
  function initCloth() {
    points = [];
    constraints = [];
    tick = 0;

    const shape = SHAPES[currentShape];
    const { cols, rows, widthFrac, startYFrac, pinned } = shape;

    const spacingX = Math.min(W * widthFrac, H * 1.1) / cols;
    const spacingY = spacingX;
    const startX = W / 2 - (cols * spacingX) / 2;
    const startY = H * startYFrac;

    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const x = startX + col * spacingX;
        const y = startY + row * spacingY;
        points.push({ x, y, px: x, py: y, pinned: pinned(row, col, cols, rows) });
      }
    }

    function idx(r: number, c: number) { return r * cols + c; }
    const diagLen = Math.hypot(spacingX, spacingY);

    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const a = points[idx(row, col)];
        if (col < cols - 1)
          constraints.push({ a, b: points[idx(row, col + 1)], len: spacingX, active: true });
        if (row < rows - 1)
          constraints.push({ a, b: points[idx(row + 1, col)], len: spacingY, active: true });
        if (col < cols - 1 && row < rows - 1)
          constraints.push({ a, b: points[idx(row + 1, col + 1)], len: diagLen, active: true });
        if (col > 0 && row < rows - 1)
          constraints.push({ a, b: points[idx(row + 1, col - 1)], len: diagLen, active: true });
      }
    }
  }

  canvas.width = W;
  canvas.height = H;
  initCloth();

  window.addEventListener('resize', () => {
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W;
    canvas.height = H;
    initCloth();
  });

  // ── Physics ──────────────────────────────────────────────────────────────────
  function step() {
    tick++;
    const tearSq = TEAR_RADIUS * TEAR_RADIUS;

    const wind = windOn
      ? WIND_FORCE * (0.6 + 0.4 * Math.sin(tick * WIND_GUST_FREQ * 6.28)) * (0.8 + 0.2 * Math.random())
      : 0;

    for (const p of points) {
      if (p.pinned) continue;
      const vx = (p.x - p.px) * DAMPING;
      const vy = (p.y - p.py) * DAMPING;
      p.px = p.x;
      p.py = p.y;
      p.x += vx + wind;
      p.y += vy + GRAVITY;
    }

    for (let i = 0; i < ITERATIONS; i++) {
      for (const c of constraints) {
        if (!c.active) continue;
        const dx = c.b.x - c.a.x;
        const dy = c.b.y - c.a.y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 0.0001;
        const diff = (dist - c.len) / dist * 0.5;
        const ox = dx * diff;
        const oy = dy * diff;
        if (!c.a.pinned) { c.a.x += ox; c.a.y += oy; }
        if (!c.b.pinned) { c.b.x -= ox; c.b.y -= oy; }
      }
    }

    for (const p of points) {
      if (p.pinned) continue;
      if (p.y > H - 2) { p.y = H - 2; p.py = p.y + (p.y - p.py) * 0.2; }
    }
  }

  // ── Render ───────────────────────────────────────────────────────────────────
  function draw() {
    ctx.clearRect(0, 0, W, H);

    ctx.strokeStyle = 'rgba(200, 200, 220, 0.75)';
    ctx.lineWidth = 0.8;
    ctx.beginPath();
    for (const c of constraints) {
      if (!c.active) continue;
      ctx.moveTo(c.a.x, c.a.y);
      ctx.lineTo(c.b.x, c.b.y);
    }
    ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    for (const p of points) {
      if (!p.pinned) continue;
      ctx.beginPath();
      ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // ── Mouse tearing ─────────────────────────────────────────────────────────────
  let mouseDown = false;

  function tear(x: number, y: number) {
    const tearSq = TEAR_RADIUS * TEAR_RADIUS;
    for (const c of constraints) {
      if (!c.active) continue;
      const midX = (c.a.x + c.b.x) * 0.5;
      const midY = (c.a.y + c.b.y) * 0.5;
      const dx = midX - x;
      const dy = midY - y;
      if (dx * dx + dy * dy < tearSq) c.active = false;
    }
  }

  canvas.addEventListener('mousedown', (e) => { mouseDown = true; tear(e.clientX, e.clientY); });
  canvas.addEventListener('mousemove', (e) => { if (mouseDown) tear(e.clientX, e.clientY); });
  canvas.addEventListener('mouseup', () => { mouseDown = false; });
  canvas.addEventListener('mouseleave', () => { mouseDown = false; });

  canvas.addEventListener('touchstart', (e) => {
    e.preventDefault(); mouseDown = true;
    tear(e.touches[0].clientX, e.touches[0].clientY);
  }, { passive: false });
  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (mouseDown) tear(e.touches[0].clientX, e.touches[0].clientY);
  }, { passive: false });
  canvas.addEventListener('touchend', (e) => { e.preventDefault(); mouseDown = false; }, { passive: false });

  // ── Wind toggle ───────────────────────────────────────────────────────────────
  const windBtn = document.getElementById('wind-btn')!;

  function setWind(on: boolean) {
    windOn = on;
    windBtn.style.borderColor = on ? 'rgba(100,200,255,0.7)' : 'rgba(255,255,255,0.4)';
    windBtn.style.color      = on ? 'rgba(100,200,255,0.9)' : 'rgba(255,255,255,0.7)';
  }

  windBtn.addEventListener('click', () => setWind(!windOn));
  document.getElementById('reset-btn')!.addEventListener('click', initCloth);

  window.addEventListener('keydown', (e) => {
    if (e.key === 'w' || e.key === 'W') setWind(!windOn);
    if (e.key === 'r' || e.key === 'R') initCloth();
  });

  // ── Shape selector ────────────────────────────────────────────────────────────
  const shapeSelect = document.getElementById('shape-select') as HTMLSelectElement;
  shapeSelect.addEventListener('change', () => {
    currentShape = shapeSelect.value as ShapeId;
    initCloth();
  });

  // ── Parameter sliders ─────────────────────────────────────────────────────────
  function bindSlider(
    id: string,
    labelId: string,
    fmt: (v: number) => string,
    onChange: (v: number) => void,
  ) {
    const input = document.getElementById(id) as HTMLInputElement;
    const label = document.getElementById(labelId)!;
    input.addEventListener('input', () => {
      const v = parseFloat(input.value);
      onChange(v);
      label.textContent = fmt(v);
    });
  }

  bindSlider('gravity-range',   'gravity-label',   v => `gravity: ${v.toFixed(2)}`,    v => { GRAVITY    = v; });
  bindSlider('damping-range',   'damping-label',   v => `damping: ${v.toFixed(3)}`,    v => { DAMPING    = v; });
  bindSlider('stiffness-range', 'stiffness-label', v => `stiffness: ${Math.round(v)}`, v => { ITERATIONS = Math.round(v); });
  bindSlider('wind-range',      'wind-label',      v => `wind strength: ${v.toFixed(2)}`, v => { WIND_FORCE  = v; });
  bindSlider('tear-range',      'tear-label',      v => `tear radius: ${Math.round(v)}`,  v => { TEAR_RADIUS = v; });

  // ── Loop ─────────────────────────────────────────────────────────────────────
  function loop() {
    step();
    draw();
    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
</script>
