---
---

<canvas id="canvas" style="display:block;width:100%;height:100%;"></canvas>

<!-- Controls panel (top-right) -->
<div
  id="controls"
  style="position:fixed;top:64px;right:24px;font-family:monospace;font-size:11px;color:rgba(255,255,255,0.7);display:flex;flex-direction:column;gap:8px;min-width:200px;"
>
  <div style="display:flex;flex-direction:column;gap:2px;margin-bottom:2px;">
    <span style="font-size:12px;color:rgba(255,255,255,0.9);letter-spacing:0.06em;">PARAMETERS</span>
  </div>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="g-label">gravity: 1.00</span>
    <input id="g-range" type="range" min="0.1" max="5" step="0.1" value="1"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="trail-label">trails: 0.04</span>
    <input id="trail-range" type="range" min="0.01" max="0.3" step="0.01" value="0.04"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="mass-label">spawn mass: 1000</span>
    <input id="mass-range" type="range" min="100" max="500000" step="100" value="1000"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="speed-label">sling speed: 2.5</span>
    <input id="speed-range" type="range" min="0.5" max="8" step="0.1" value="2.5"
      style="accent-color:white;width:100%;" />
  </label>

  <label style="display:flex;flex-direction:column;gap:3px;">
    <span id="forces-label">show forces: on</span>
    <input id="forces-range" type="range" min="0" max="1" step="1" value="1"
      style="accent-color:white;width:100%;" />
  </label>

  <div style="display:flex;gap:6px;margin-top:4px;">
    <button id="reset-btn"
      style="flex:1;background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:11px;padding:5px 8px;cursor:pointer;letter-spacing:0.08em;"
    >RESET [R]</button>
    <button id="fit-btn"
      style="flex:1;background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.7);font-family:monospace;font-size:11px;padding:5px 8px;cursor:pointer;letter-spacing:0.08em;"
    >FIT [F]</button>
  </div>
</div>

<script>
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = window.innerWidth, H = window.innerHeight;
  canvas.width = W; canvas.height = H;

  window.addEventListener('resize', () => {
    W = window.innerWidth; H = window.innerHeight;
    canvas.width = W; canvas.height = H;
  });

  // ── Tunable params ───────────────────────────────────────────────────────
  let G = 1;
  let TRAIL_FADE = 0.04;
  let SPAWN_MASS = 1000;
  let SLING_SCALE = 2.5;
  let SHOW_FORCES = true;

  // ── UI wiring ────────────────────────────────────────────────────────────
  const gRange      = document.getElementById('g-range')      as HTMLInputElement;
  const gLabel      = document.getElementById('g-label')!;
  const trailRange  = document.getElementById('trail-range')  as HTMLInputElement;
  const trailLabel  = document.getElementById('trail-label')!;
  const massRange   = document.getElementById('mass-range')   as HTMLInputElement;
  const massLabel   = document.getElementById('mass-label')!;
  const speedRange  = document.getElementById('speed-range')  as HTMLInputElement;
  const speedLabel  = document.getElementById('speed-label')!;
  const forcesRange = document.getElementById('forces-range') as HTMLInputElement;
  const forcesLabel = document.getElementById('forces-label')!;

  gRange.addEventListener('input', () => {
    G = parseFloat(gRange.value);
    gLabel.textContent = `gravity: ${G.toFixed(2)}`;
  });
  trailRange.addEventListener('input', () => {
    TRAIL_FADE = parseFloat(trailRange.value);
    trailLabel.textContent = `trails: ${TRAIL_FADE.toFixed(2)}`;
  });
  massRange.addEventListener('input', () => {
    SPAWN_MASS = parseInt(massRange.value);
    massLabel.textContent = `spawn mass: ${SPAWN_MASS}`;
  });
  speedRange.addEventListener('input', () => {
    SLING_SCALE = parseFloat(speedRange.value);
    speedLabel.textContent = `sling speed: ${SLING_SCALE.toFixed(1)}`;
  });
  forcesRange.addEventListener('input', () => {
    SHOW_FORCES = forcesRange.value === '1';
    forcesLabel.textContent = `show forces: ${SHOW_FORCES ? 'on' : 'off'}`;
  });

  // ── Camera ───────────────────────────────────────────────────────────────
  let zoom = 1;
  let camX = 0; // world coords at screen center
  let camY = 0;

  function screenToWorld(sx: number, sy: number) {
    return {
      x: (sx - W / 2) / zoom + camX,
      y: (sy - H / 2) / zoom + camY,
    };
  }

  function fitView() {
    zoom = 1;
    camX = W / 2;
    camY = H / 2;
  }

  // ── Bodies ───────────────────────────────────────────────────────────────
  const MAX_BODIES = 128;
  const _ax = new Float64Array(MAX_BODIES);
  const _ay = new Float64Array(MAX_BODIES);

  interface Body {
    x: number; y: number;
    vx: number; vy: number;
    mass: number; radius: number;
    color: string;
    dead: boolean;
  }

  let bodies: Body[] = [];

  function mkBody(
    x: number, y: number,
    vx: number, vy: number,
    mass: number, color: string,
    radius?: number
  ): Body {
    return {
      x, y, vx, vy, mass,
      radius: radius ?? Math.max(4, Math.cbrt(mass) * 0.45),
      color, dead: false,
    };
  }

  // ── Scene setup ──────────────────────────────────────────────────────────
  const STAR_MASS = 3_000_000;
  const PALETTE = ['#f48fb1','#ce93d8','#81d4fa','#80cbc4','#fff176','#ffcc80','#ef9a9a','#b39ddb'];
  let pidx = 0;
  const nextColor = () => PALETTE[pidx++ % PALETTE.length];

  function initBodies() {
    bodies = [];
    pidx = 0;
    const D = Math.min(W, H);
    const ox = W / 2, oy = H / 2;

    bodies.push(mkBody(ox, oy, 0, 0, STAR_MASS, '#ffe680', D * 0.025));

    const initialOrbits = [
      { r: D * 0.17, mass: 4000,  color: '#4fc3f7' },
      { r: D * 0.30, mass: 9000,  color: '#ef9a9a' },
      { r: D * 0.44, mass: 5000,  color: '#a5d6a7' },
    ];

    for (const { r, mass, color } of initialOrbits) {
      const a = Math.random() * Math.PI * 2;
      const v = Math.sqrt(G * STAR_MASS / r);
      bodies.push(mkBody(
        ox + Math.cos(a) * r, oy + Math.sin(a) * r,
        -Math.sin(a) * v,     Math.cos(a) * v,
        mass, color
      ));
    }

    fitView();
    ctx.clearRect(0, 0, W, H);
  }

  initBodies();

  document.getElementById('reset-btn')!.addEventListener('click', initBodies);
  document.getElementById('fit-btn')!.addEventListener('click', () => { fitView(); ctx.clearRect(0, 0, W, H); });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'r' || e.key === 'R') initBodies();
    if (e.key === 'f' || e.key === 'F') { fitView(); ctx.clearRect(0, 0, W, H); }
  });

  // ── Scroll / pinch zoom ──────────────────────────────────────────────────
  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    const wx = (e.clientX - W / 2) / zoom + camX;
    const wy = (e.clientY - H / 2) / zoom + camY;
    zoom = Math.max(0.05, Math.min(20, zoom * factor));
    camX = wx - (e.clientX - W / 2) / zoom;
    camY = wy - (e.clientY - H / 2) / zoom;
  }, { passive: false });

  // Pinch zoom
  let lastPinchDist = 0;
  canvas.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      lastPinchDist = Math.hypot(
        e.touches[1].clientX - e.touches[0].clientX,
        e.touches[1].clientY - e.touches[0].clientY
      );
    }
  }, { passive: true });
  canvas.addEventListener('touchmove', (e) => {
    if (e.touches.length === 2) {
      e.preventDefault();
      const d = Math.hypot(
        e.touches[1].clientX - e.touches[0].clientX,
        e.touches[1].clientY - e.touches[0].clientY
      );
      if (lastPinchDist > 0) {
        const factor = d / lastPinchDist;
        const mx = (e.touches[0].clientX + e.touches[1].clientX) / 2;
        const my = (e.touches[0].clientY + e.touches[1].clientY) / 2;
        const wx = (mx - W / 2) / zoom + camX;
        const wy = (my - H / 2) / zoom + camY;
        zoom = Math.max(0.05, Math.min(20, zoom * factor));
        camX = wx - (mx - W / 2) / zoom;
        camY = wy - (my - H / 2) / zoom;
      }
      lastPinchDist = d;
    }
  }, { passive: false });

  // ── Physics ──────────────────────────────────────────────────────────────
  interface ForcePair { i: number; j: number; f: number; }
  let lastForces: ForcePair[] = [];

  function physics(dt: number) {
    const SUB = 8, sdt = dt / SUB;
    const n = bodies.length;
    lastForces = [];

    for (let i = 0; i < n; i++) {
      if (bodies[i].dead) continue;
      for (let j = i + 1; j < n; j++) {
        if (bodies[j].dead) continue;
        const dx = bodies[j].x - bodies[i].x;
        const dy = bodies[j].y - bodies[i].y;
        const r2 = Math.max(dx * dx + dy * dy, 36);
        lastForces.push({ i, j, f: G * bodies[i].mass * bodies[j].mass / r2 });
      }
    }

    for (let s = 0; s < SUB; s++) {
      _ax.fill(0, 0, n);
      _ay.fill(0, 0, n);

      for (let i = 0; i < n; i++) {
        if (bodies[i].dead) continue;
        for (let j = i + 1; j < n; j++) {
          if (bodies[j].dead) continue;
          const dx = bodies[j].x - bodies[i].x;
          const dy = bodies[j].y - bodies[i].y;
          const r2 = dx * dx + dy * dy;
          const soft = Math.max(Math.sqrt(r2), 6);
          const f = G / (soft * soft * soft);
          _ax[i] += f * bodies[j].mass * dx; _ay[i] += f * bodies[j].mass * dy;
          _ax[j] -= f * bodies[i].mass * dx; _ay[j] -= f * bodies[i].mass * dy;
        }
      }

      for (let i = 0; i < n; i++) {
        if (bodies[i].dead) continue;
        bodies[i].vx += _ax[i] * sdt;
        bodies[i].vy += _ay[i] * sdt;
        bodies[i].x  += bodies[i].vx * sdt;
        bodies[i].y  += bodies[i].vy * sdt;
      }
    }

    // Merges
    for (let i = 0; i < n; i++) {
      if (bodies[i].dead) continue;
      for (let j = i + 1; j < n; j++) {
        if (bodies[j].dead) continue;
        if (Math.hypot(bodies[j].x - bodies[i].x, bodies[j].y - bodies[i].y) < bodies[i].radius + bodies[j].radius) {
          const tm = bodies[i].mass + bodies[j].mass;
          bodies[i].vx = (bodies[i].vx * bodies[i].mass + bodies[j].vx * bodies[j].mass) / tm;
          bodies[i].vy = (bodies[i].vy * bodies[i].mass + bodies[j].vy * bodies[j].mass) / tm;
          bodies[i].x  = (bodies[i].x  * bodies[i].mass + bodies[j].x  * bodies[j].mass) / tm;
          bodies[i].y  = (bodies[i].y  * bodies[i].mass + bodies[j].y  * bodies[j].mass) / tm;
          bodies[i].mass = tm;
          bodies[i].radius = Math.max(bodies[i].radius, Math.cbrt(tm) * 0.45);
          bodies[j].dead = true;
        }
      }
    }

    for (let i = bodies.length - 1; i >= 0; i--) {
      if (bodies[i].dead) { bodies.splice(i, 1); continue; }
      // Escape: > 8× screen diagonal from origin
      const ox = W / 2, oy = H / 2;
      if (Math.hypot(bodies[i].x - ox, bodies[i].y - oy) > Math.hypot(W, H) * 8)
        bodies.splice(i, 1);
    }
  }

  // ── Draw ─────────────────────────────────────────────────────────────────
  function applyCamera() {
    ctx.translate(W / 2, H / 2);
    ctx.scale(zoom, zoom);
    ctx.translate(-camX, -camY);
  }

  function draw() {
    // Trail fade in screen space (persists across zoom changes intentionally)
    ctx.fillStyle = `rgba(0,0,0,${TRAIL_FADE})`;
    ctx.fillRect(0, 0, W, H);

    ctx.save();
    applyCamera();

    // Force lines
    if (SHOW_FORCES && lastForces.length > 0) {
      const maxF = Math.max(...lastForces.map(p => p.f));
      for (const { i, j, f } of lastForces) {
        if (i >= bodies.length || j >= bodies.length) continue;
        const bi = bodies[i], bj = bodies[j];
        const alpha = Math.min(0.65, (f / maxF) * 0.65);
        if (alpha < 0.03) continue;
        const grad = ctx.createLinearGradient(bi.x, bi.y, bj.x, bj.y);
        grad.addColorStop(0, bi.color);
        grad.addColorStop(1, bj.color);
        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.strokeStyle = grad;
        ctx.lineWidth = Math.max(0.5, (f / maxF) * 2.5) / zoom;
        ctx.beginPath();
        ctx.moveTo(bi.x, bi.y);
        ctx.lineTo(bj.x, bj.y);
        ctx.stroke();
        ctx.restore();
      }
    }

    // Bodies
    for (const b of bodies) {
      ctx.globalAlpha = 0.18;
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.radius * 3, 0, Math.PI * 2);
      ctx.fillStyle = b.color;
      ctx.fill();
      ctx.globalAlpha = 1;

      ctx.beginPath();
      ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
      ctx.fillStyle = b.color;
      ctx.fill();
    }

    ctx.restore();
  }

  // ── Slingshot ─────────────────────────────────────────────────────────────
  let dragging = false;
  let dragA = { x: 0, y: 0 }; // world space
  let dragB = { x: 0, y: 0 }; // world space
  let dragColor = '';

  function onDown(sx: number, sy: number) {
    dragging = true;
    dragA = screenToWorld(sx, sy);
    dragB = { ...dragA };
    dragColor = nextColor();
  }
  function onMove(sx: number, sy: number) {
    if (dragging) dragB = screenToWorld(sx, sy);
  }
  function onUp() {
    if (!dragging) return;
    dragging = false;
    // Slingshot: velocity opposite to pull direction
    const vx = (dragA.x - dragB.x) * SLING_SCALE;
    const vy = (dragA.y - dragB.y) * SLING_SCALE;
    bodies.push(mkBody(dragA.x, dragA.y, vx, vy, SPAWN_MASS, dragColor));
  }

  canvas.addEventListener('mousedown',  (e) => onDown(e.clientX, e.clientY));
  canvas.addEventListener('mousemove',  (e) => onMove(e.clientX, e.clientY));
  canvas.addEventListener('mouseup',    () => onUp());
  canvas.addEventListener('mouseleave', () => { dragging = false; });

  canvas.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) { e.preventDefault(); onDown(e.touches[0].clientX, e.touches[0].clientY); }
  }, { passive: false });
  canvas.addEventListener('touchmove', (e) => {
    if (e.touches.length === 1) { e.preventDefault(); onMove(e.touches[0].clientX, e.touches[0].clientY); }
  }, { passive: false });
  canvas.addEventListener('touchend', (e) => {
    if (e.changedTouches.length === 1 && e.touches.length === 0) { e.preventDefault(); onUp(); }
  }, { passive: false });

  function drawSlingshot() {
    if (!dragging) return;
    const dx = dragB.x - dragA.x;
    const dy = dragB.y - dragA.y;
    const len = Math.hypot(dx, dy);
    if (len < 2) return;

    ctx.save();
    applyCamera();
    ctx.lineWidth = 1 / zoom;

    // Pull band A→B (dim)
    ctx.setLineDash([4 / zoom, 4 / zoom]);
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.beginPath();
    ctx.moveTo(dragA.x, dragA.y);
    ctx.lineTo(dragB.x, dragB.y);
    ctx.stroke();
    ctx.setLineDash([]);

    // Launch vector A → opposite (bright, colored)
    const lx = dragA.x - dx, ly = dragA.y - dy;
    ctx.globalAlpha = 0.85;
    ctx.strokeStyle = dragColor;
    ctx.beginPath();
    ctx.moveTo(dragA.x, dragA.y);
    ctx.lineTo(lx, ly);
    ctx.stroke();

    // Arrowhead
    const nx = -dx / len, ny = -dy / len;
    const px = -ny, py = nx;
    const aw = 10 / zoom;
    ctx.beginPath();
    ctx.moveTo(lx, ly);
    ctx.lineTo(lx - nx * aw + px * aw * 0.5, ly - ny * aw + py * aw * 0.5);
    ctx.moveTo(lx, ly);
    ctx.lineTo(lx - nx * aw - px * aw * 0.5, ly - ny * aw - py * aw * 0.5);
    ctx.stroke();

    // Crosshair at spawn
    const ch = 8 / zoom;
    ctx.globalAlpha = 0.6;
    ctx.strokeStyle = dragColor;
    ctx.beginPath();
    ctx.moveTo(dragA.x - ch, dragA.y); ctx.lineTo(dragA.x + ch, dragA.y);
    ctx.moveTo(dragA.x, dragA.y - ch); ctx.lineTo(dragA.x, dragA.y + ch);
    ctx.stroke();

    ctx.restore();
  }

  // ── Loop ─────────────────────────────────────────────────────────────────
  let last = 0;
  function loop(t: number) {
    const dt = Math.min((t - last) / 1000, 0.05);
    last = t;
    if (dt > 0) physics(dt);
    draw();
    drawSlingshot();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
</script>
