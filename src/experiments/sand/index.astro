---

---

<canvas
  id="canvas"
  style="display:block;width:100%;height:100%;image-rendering:pixelated;cursor:crosshair;"
></canvas>

<div id="controls">
  <div class="section-title">MATERIAL</div>
  <button class="mat-btn active" data-mat="1">SAND [1]</button>
  <button class="mat-btn" data-mat="2">WATER [2]</button>
  <button class="mat-btn" data-mat="3">FIRE [3]</button>
  <button class="mat-btn" data-mat="4">WALL [4]</button>
  <button class="mat-btn" data-mat="6">SOIL [6]</button>
  <button class="mat-btn" data-mat="7">GRAVITY [5]</button>
  <button class="mat-btn" data-mat="0">ERASE [E]</button>
  <div class="divider"></div>
  <label>
    <span id="brush-label">brush: 5</span>
    <input id="brush-range" type="range" min="1" max="20" step="1" value="5" />
  </label>
  <div class="divider"></div>
  <label class="toggle-label">
    <input id="gravity-toggle" type="checkbox" />
    <span>global gravity</span>
  </label>
  <div class="divider"></div>
  <button id="btn-clear">CLEAR [C]</button>
</div>

<style>
  #controls {
    position: fixed;
    top: 64px;
    right: 24px;
    font-family: monospace;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 130px;
  }
  .section-title {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.06em;
    margin-bottom: 2px;
  }
  .mat-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.55);
    font-family: monospace;
    font-size: 11px;
    padding: 5px 10px;
    cursor: pointer;
    letter-spacing: 0.06em;
    text-align: left;
  }
  .mat-btn.active {
    border-color: rgba(255, 255, 255, 0.8);
    color: rgba(255, 255, 255, 0.95);
  }
  #btn-clear {
    background: transparent;
    border: 1px solid rgba(255, 100, 100, 0.4);
    color: rgba(255, 150, 150, 0.7);
    font-family: monospace;
    font-size: 11px;
    padding: 5px 10px;
    cursor: pointer;
    letter-spacing: 0.06em;
    text-align: left;
  }
  .divider {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 1px 0;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  input[type="range"] {
    accent-color: white;
    width: 100%;
  }
  .toggle-label {
    flex-direction: row;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }
  .toggle-label input {
    accent-color: white;
    cursor: pointer;
  }
</style>

<script>
  // ── Constants ───────────────────────────────────────────────────────────────
  const CELL = 3;
  const EMPTY = 0,
    SAND = 1,
    WATER = 2,
    FIRE = 3,
    WALL = 4,
    SMOKE = 5,
    SOIL = 6,
    ATTRACTOR = 7;

  // ── Canvas setup ────────────────────────────────────────────────────────────
  const canvas = document.getElementById("canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  let COLS = 0,
    ROWS = 0;
  let grid: Uint8Array, colr: Uint8Array, life: Uint8Array, moved: Uint8Array;
  let imageData: ImageData;
  let pixels: Uint32Array;
  let frameCount = 0;

  function initGrid(newCols: number, newRows: number) {
    const oldGrid = grid,
      oldColr = colr,
      oldLife = life;
    const oldCols = COLS,
      oldRows = ROWS;

    COLS = newCols;
    ROWS = newRows;
    grid = new Uint8Array(COLS * ROWS);
    colr = new Uint8Array(COLS * ROWS);
    life = new Uint8Array(COLS * ROWS);
    moved = new Uint8Array(COLS * ROWS);

    if (oldGrid) {
      const minC = Math.min(COLS, oldCols);
      const minR = Math.min(ROWS, oldRows);
      for (let y = 0; y < minR; y++) {
        for (let x = 0; x < minC; x++) {
          const oi = y * oldCols + x;
          const ni = y * COLS + x;
          grid[ni] = oldGrid[oi];
          colr[ni] = oldColr[oi];
          life[ni] = oldLife[oi];
        }
      }
    }

    canvas.width = COLS;
    canvas.height = ROWS;
    imageData = ctx.createImageData(COLS, ROWS);
    pixels = new Uint32Array(imageData.data.buffer);
  }

  initGrid(
    Math.floor(window.innerWidth / CELL),
    Math.floor(window.innerHeight / CELL),
  );

  window.addEventListener("resize", () => {
    initGrid(
      Math.floor(window.innerWidth / CELL),
      Math.floor(window.innerHeight / CELL),
    );
  });

  // ── Cell helpers ────────────────────────────────────────────────────────────
  function place(
    idx: number,
    type: number,
    variation?: number,
    lifetime?: number,
  ) {
    grid[idx] = type;
    colr[idx] = variation ?? (Math.random() * 256) | 0;
    life[idx] = lifetime ?? 0;
  }

  function swapCells(a: number, b: number) {
    let tmp: number;
    tmp = grid[a];
    grid[a] = grid[b];
    grid[b] = tmp;
    tmp = colr[a];
    colr[a] = colr[b];
    colr[b] = tmp;
    tmp = life[a];
    life[a] = life[b];
    life[b] = tmp;
  }

  // ── Simulation rules ────────────────────────────────────────────────────────

  type MaterialConfig = {
    sidewaysFlow: boolean;
    gravity: number;
    density: number;
    ephemeral: boolean;
    brushRadius?: number;
    deathMaterial?: number;
    deathLife?: () => number;
    sideEffect?: (x: number, y: number, idx: number) => void;
  };

  const defaultMaterialConfig: MaterialConfig = {
    sidewaysFlow: false,
    gravity: 1,
    density: 10,
    ephemeral: false,
  };

  function fireSideEffect(x: number, y: number, idx: number) {
    const nbrs = [
      y > 0 ? idx - COLS : -1,
      y + 1 < ROWS ? idx + COLS : -1,
      x > 0 ? idx - 1 : -1,
      x + 1 < COLS ? idx + 1 : -1,
    ];
    for (const ni of nbrs) {
      if (ni < 0) continue;
      const nt = grid[ni];
      if (nt === SAND && Math.random() < 0.015) {
        place(ni, FIRE, undefined, (30 + Math.random() * 60) | 0);
        moved[ni] = 1;
      } else if (nt === WATER) {
        grid[idx] = SMOKE;
        life[idx] = (8 + Math.random() * 12) | 0;
        return;
      }
    }
    if (y > 0 && Math.random() < 0.18) {
      const above = idx - COLS;
      if (grid[above] === EMPTY) {
        place(above, SMOKE, undefined, (20 + Math.random() * 35) | 0);
        moved[above] = 1;
      }
    }
  }

  const materialConfigs: { [key: number]: Partial<MaterialConfig> } = {
    [SAND]: {},
    [SOIL]: { density: 15 },
    [WATER]: { sidewaysFlow: true, density: 2 },
    [FIRE]: {
      gravity: 0,
      ephemeral: true,
      density: 1,
      deathMaterial: SMOKE,
      deathLife: () => (30 + Math.random() * 40) | 0,
      sideEffect: fireSideEffect,
    },
    [WALL]: { density: 20 },
    [SMOKE]: { gravity: -1, ephemeral: true, density: 1 },
    [ATTRACTOR]: { gravity: 0, density: 30, brushRadius: 1 },
  };

  function getMaterialConfig(material: number): MaterialConfig {
    return Object.assign(
      {},
      defaultMaterialConfig,
      materialConfigs[material] || {},
    );
  }

  function lighterThan(materialA: number, materialB: number) {
    const materialAConfig = getMaterialConfig(materialA);
    const materialBConfig = getMaterialConfig(materialB);
    return materialAConfig.density < materialBConfig.density;
  }

  function updateParticle(material: number, x: number, y: number, idx: number) {
    const materialConfig = getMaterialConfig(material);

    if (materialConfig.ephemeral && --life[idx] <= 0) {
      const death = materialConfig.deathMaterial ?? EMPTY;
      grid[idx] = death;
      if (materialConfig.deathLife) life[idx] = materialConfig.deathLife();
      if (death !== EMPTY) colr[idx] = (Math.random() * 256) | 0;
      return;
    }

    if (materialConfig.sideEffect) {
      materialConfig.sideEffect(x, y, idx);
      if (grid[idx] !== material) return;
    }

    if (globalGravity && materialConfig.gravity != 0) {
      if (materialConfig.gravity > 0 ? y + 1 >= ROWS : y <= 0) return;

      const below = idx + COLS * Math.sign(materialConfig.gravity);
      const bt = grid[below];
      if (bt === EMPTY || lighterThan(bt, material)) {
        swapCells(idx, below);
        moved[below] = 1;
        return;
      }
      const d1 = Math.random() < 0.5 ? -1 : 1;
      for (const dx of [d1, -d1]) {
        const nx = x + dx;
        if (nx < 0 || nx >= COLS) continue;
        const nidx = below + dx;
        const nt = grid[nidx];
        if (nt === EMPTY || lighterThan(nt, material)) {
          swapCells(idx, nidx);
          moved[nidx] = 1;
          return;
        }
      }

      if (materialConfig.sidewaysFlow) {
        // Sideways flow
        const d1 = Math.random() < 0.5 ? -1 : 1;
        for (const dx of [d1, -d1]) {
          const nx = x + dx;
          if (nx < 0 || nx >= COLS) continue;
          const nidx = idx + dx;
          if (grid[nidx] === EMPTY) {
            swapCells(idx, nidx);
            moved[nidx] = 1;
            return;
          }
        }
      }
    }
  }

  const ATTRACTOR_RADIUS = 100;
  const ATTRACTOR_STRENGTH = 300;

  function applyAttractors() {
    for (let ay = 0; ay < ROWS; ay++) {
      for (let ax = 0; ax < COLS; ax++) {
        if (grid[ay * COLS + ax] !== ATTRACTOR) continue;
        for (let dy = -ATTRACTOR_RADIUS; dy <= ATTRACTOR_RADIUS; dy++) {
          for (let dx = -ATTRACTOR_RADIUS; dx <= ATTRACTOR_RADIUS; dx++) {
            if (dx === 0 && dy === 0) continue;
            const px = ax + dx,
              py = ay + dy;
            if (px < 0 || px >= COLS || py < 0 || py >= ROWS) continue;
            const pidx = py * COLS + px;
            const pt = grid[pidx];
            if (pt === EMPTY || pt === WALL || pt === ATTRACTOR) continue;
            const dist2 = dx * dx + dy * dy;
            if (Math.random() > Math.min(ATTRACTOR_STRENGTH / dist2, 0.9))
              continue;
            // Try to move one step toward attractor
            const sdx = -Math.sign(dx),
              sdy = -Math.sign(dy);
            const candidates: [number, number][] =
              sdx !== 0 && sdy !== 0
                ? [
                    [sdx, sdy],
                    [sdx, 0],
                    [0, sdy],
                  ]
                : [[sdx, sdy]];
            for (const [mx, my] of candidates) {
              const nx = px + mx,
                ny = py + my;
              if (nx < 0 || nx >= COLS || ny < 0 || ny >= ROWS) continue;
              const nidx = ny * COLS + nx;
              if (grid[nidx] === EMPTY) {
                swapCells(pidx, nidx);
                moved[nidx] = 1;
                break;
              }
            }
          }
        }
      }
    }
  }

  function step() {
    moved.fill(0);
    applyAttractors();

    // Bottom-to-top: falling particles (gravity > 0)
    for (let y = ROWS - 1; y >= 0; y--) {
      const ltr = (frameCount + y) % 2 === 0;
      for (let xi = 0; xi < COLS; xi++) {
        const x = ltr ? xi : COLS - 1 - xi;
        const idx = y * COLS + x;
        if (moved[idx]) continue;
        const t = grid[idx];
        if (t === EMPTY) continue;
        if (getMaterialConfig(t).gravity > 0) updateParticle(t, x, y, idx);
      }
    }

    // Top-to-bottom: rising/static particles (gravity <= 0)
    for (let y = 0; y < ROWS; y++) {
      for (let x = 0; x < COLS; x++) {
        const idx = y * COLS + x;
        if (moved[idx]) continue;
        const t = grid[idx];
        if (t === EMPTY) continue;
        if (getMaterialConfig(t).gravity <= 0) updateParticle(t, x, y, idx);
      }
    }
  }

  // ── Rendering ───────────────────────────────────────────────────────────────
  // Pixel format (little-endian Uint32): 0xAABBGGRR
  function render() {
    const n = COLS * ROWS;
    for (let i = 0; i < n; i++) {
      const t = grid[i];
      let px = 0xff000000; // black

      if (t === SAND) {
        const v = colr[i];
        const r = 188 + (v >> 4) - 8;
        const g = 155 + (v >> 5) - 4;
        const b = 88 + (v >> 6);
        px = (0xff000000 | (b << 16) | (g << 8) | r) >>> 0;
      } else if (t === WATER) {
        const v = colr[i];
        const r = 25;
        const g = 88 + (v >> 4);
        const b = 190 + (v >> 5);
        px = (0xff000000 | (b << 16) | (g << 8) | r) >>> 0;
      } else if (t === FIRE) {
        const v = colr[i];
        const flick = (Math.random() * 80) | 0;
        const r = 255;
        const g = Math.min(220, (v >> 1) + flick);
        const b = flick > 65 ? (flick - 65) * 3 : 0;
        px = (0xff000000 | (b << 16) | (g << 8) | r) >>> 0;
      } else if (t === SOIL) {
        const v = colr[i];
        const r = 101 + (v >> 5);
        const g = 67 + (v >> 5);
        const b = 33 + (v >> 6);
        px = (0xff000000 | (b << 16) | (g << 8) | r) >>> 0;
      } else if (t === WALL) {
        const v = colr[i];
        const s = 75 + (v >> 4);
        px = (0xff000000 | (s << 16) | (s << 8) | s) >>> 0;
      } else if (t === SMOKE) {
        const v = colr[i];
        const l = life[i];
        const alpha = Math.min(220, (l / 60) * 220) | 0;
        const s = 130 + (v >> 4);
        px = ((alpha << 24) | (s << 16) | (s << 8) | s) >>> 0;
      } else if (t === ATTRACTOR) {
        px = (0xff000000 | (40 << 16) | (20 << 8) | 60) >>> 0;
      }

      pixels[i] = px;
    }
    ctx.putImageData(imageData, 0, 0);
  }

  // ── Drawing input ───────────────────────────────────────────────────────────
  let globalGravity = false;

  let drawing = false;
  let currentMat = SAND;
  let brushRadius = 5;

  function screenToGrid(cx: number, cy: number) {
    const rect = canvas.getBoundingClientRect();
    const gx = Math.floor(((cx - rect.left) / rect.width) * COLS);
    const gy = Math.floor(((cy - rect.top) / rect.height) * ROWS);
    return { gx, gy };
  }

  function drawAt(cx: number, cy: number) {
    const { gx, gy } = screenToGrid(cx, cy);

    const materialConfig = getMaterialConfig(currentMat); // to ensure currentMat is valid

    const r = materialConfig.brushRadius ?? brushRadius;
    const r2 = r * r;
    for (let dy = -r; dy <= r; dy++) {
      for (let dx = -r; dx <= r; dx++) {
        if (dx * dx + dy * dy > r2) continue;
        const nx = gx + dx,
          ny = gy + dy;
        if (nx < 0 || nx >= COLS || ny < 0 || ny >= ROWS) continue;
        const idx = ny * COLS + nx;
        if (currentMat === EMPTY) {
          grid[idx] = EMPTY;
          colr[idx] = 0;
          life[idx] = 0;
        } else if (grid[idx] !== WALL || currentMat === WALL) {
          if (currentMat === FIRE) {
            place(idx, FIRE, undefined, (40 + Math.random() * 60) | 0);
          } else if (currentMat === ATTRACTOR) {
            place(idx, ATTRACTOR, 0, 0);
          } else {
            place(idx, currentMat);
          }
        }
      }
    }
  }

  canvas.addEventListener("mousedown", (e) => {
    drawing = true;
    drawAt(e.clientX, e.clientY);
  });
  canvas.addEventListener("mousemove", (e) => {
    if (drawing) drawAt(e.clientX, e.clientY);
  });
  canvas.addEventListener("mouseup", () => {
    drawing = false;
  });
  canvas.addEventListener("mouseleave", () => {
    drawing = false;
  });

  canvas.addEventListener(
    "touchstart",
    (e) => {
      e.preventDefault();
      drawing = true;
      drawAt(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchmove",
    (e) => {
      e.preventDefault();
      if (drawing) drawAt(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchend",
    (e) => {
      e.preventDefault();
      drawing = false;
    },
    { passive: false },
  );

  // ── UI ──────────────────────────────────────────────────────────────────────
  function setMaterial(mat: number) {
    currentMat = mat;
    document.querySelectorAll(".mat-btn").forEach((btn) => {
      const el = btn as HTMLElement;
      el.classList.toggle("active", parseInt(el.dataset.mat!) === mat);
    });
  }

  document.querySelectorAll(".mat-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      setMaterial(parseInt((btn as HTMLElement).dataset.mat!));
    });
  });

  document.getElementById("btn-clear")!.addEventListener("click", () => {
    grid.fill(0);
    colr.fill(0);
    life.fill(0);
  });

  const brushRange = document.getElementById("brush-range") as HTMLInputElement;
  const brushLabel = document.getElementById("brush-label")!;
  brushRange.addEventListener("input", () => {
    brushRadius = parseInt(brushRange.value);
    brushLabel.textContent = `brush: ${brushRadius}`;
  });

  const gravityToggle = document.getElementById(
    "gravity-toggle",
  ) as HTMLInputElement;
  gravityToggle.checked = globalGravity;
  gravityToggle.addEventListener("change", () => {
    globalGravity = gravityToggle.checked;
  });

  window.addEventListener("keydown", (e) => {
    switch (e.key) {
      case "1":
        setMaterial(SAND);
        break;
      case "2":
        setMaterial(WATER);
        break;
      case "3":
        setMaterial(FIRE);
        break;
      case "4":
        setMaterial(WALL);
        break;
      case "5":
        setMaterial(ATTRACTOR);
        break;
      case "6":
        setMaterial(SOIL);
        break;
      case "e":
      case "E":
        setMaterial(EMPTY);
        break;
      case "c":
      case "C":
        grid.fill(0);
        colr.fill(0);
        life.fill(0);
        break;
    }
  });

  // ── Loop ────────────────────────────────────────────────────────────────────
  function loop() {
    step();
    render();
    frameCount++;
    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
</script>
