---
import twoImg from './two.png';
---

<canvas
  id="canvas"
  data-img={twoImg.src}
  style="display:block;width:100%;height:100%;position:fixed;top:0;left:0;"
></canvas>

<!-- Scroll hint -->
<div id="scroll-hint" style="
  position:fixed;
  bottom:44px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:6px;
  color:rgba(255,255,255,0.45);
  font-family:monospace;
  font-size:11px;
  letter-spacing:0.12em;
  pointer-events:none;
  user-select:none;
  transition:opacity 0.6s;
">
  <span id="hint-label">SCROLL</span>
  <svg id="hint-arrow" width="14" height="20" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg"
    style="animation:hint-bounce 1.4s ease-in-out infinite;">
    <line x1="7" y1="0" x2="7" y2="14" stroke="currentColor" stroke-width="1.5"/>
    <polyline points="2,9 7,15 12,9" stroke="currentColor" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- Progress track + knot -->
<div id="prog-track" style="
  position:fixed;
  right:18px;
  top:64px;
  bottom:20px;
  width:2px;
  background:rgba(255,255,255,0.12);
  border-radius:1px;
  cursor:pointer;
">
  <div id="prog-knot" style="
    position:absolute;
    left:50%;
    transform:translate(-50%, -50%);
    top:0%;
    width:8px;
    height:8px;
    border-radius:50%;
    background:rgba(255,255,255,0.9);
    box-shadow:0 0 6px rgba(255,255,255,0.4);
    cursor:grab;
    touch-action:none;
  "></div>
</div>

<style is:global>
  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.45; }
    50%       { transform: translateY(5px); opacity: 0.9; }
  }
</style>

<script>
import * as THREE from 'three';

const isMobile = window.matchMedia('(pointer: coarse)').matches;

// --- UI refs ---
const hint  = document.getElementById('scroll-hint') as HTMLElement;
const hintLabel = document.getElementById('hint-label') as HTMLElement;
const track = document.getElementById('prog-track') as HTMLElement;
const knot  = document.getElementById('prog-knot') as HTMLElement;

if (isMobile) {
  hintLabel.textContent = 'SWIPE OR DRAG';
  // Bigger knob on touch
  knot.style.width  = '22px';
  knot.style.height = '22px';
  track.style.width = '3px';
}

// --- Shared scroll state (mutated by both wheel/touch and slider) ---
let scrollTarget = 0.15;
let scrollProg   = 0.15;
let sliderActive = false;

function progressFromY(clientY: number): number {
  const r = track.getBoundingClientRect();
  return Math.max(0, Math.min(1, (clientY - r.top) / r.height));
}

// Pointer-capture drag on the knot (works for mouse and touch)
knot.addEventListener('pointerdown', (e) => {
  sliderActive = true;
  knot.setPointerCapture(e.pointerId);
  knot.style.cursor = 'grabbing';
  e.stopPropagation();
});
knot.addEventListener('pointermove', (e) => {
  if (!sliderActive) return;
  scrollTarget = progressFromY(e.clientY);
  e.stopPropagation();
});
knot.addEventListener('pointerup',     () => { sliderActive = false; knot.style.cursor = 'grab'; });
knot.addEventListener('pointercancel', () => { sliderActive = false; knot.style.cursor = 'grab'; });

// Click anywhere on the track to jump
track.addEventListener('pointerdown', (e) => {
  if (e.target === knot) return;
  scrollTarget = progressFromY(e.clientY);
});

// --- Main ---
async function main() {
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const imgSrc = canvas.dataset.img!;

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 1);

  const scene  = new THREE.Scene();
  const FOV    = 60;
  const CAM_Z  = 700;
  const camera = new THREE.PerspectiveCamera(FOV, innerWidth / innerHeight, 1, 4000);
  camera.position.z = CAM_Z;

  function resize() {
    renderer.setSize(innerWidth, innerHeight);
    camera.aspect = innerWidth / innerHeight;
    camera.updateProjectionMatrix();
  }
  resize();
  window.addEventListener('resize', resize);

  // --- Sample dark pixels ---
  const img = new Image();
  img.src = imgSrc;
  await new Promise<void>((res) => { img.onload = () => res(); });

  const IW = img.naturalWidth;
  const IH = img.naturalHeight;

  const offscreen = document.createElement('canvas');
  offscreen.width = IW; offscreen.height = IH;
  const ctx2d = offscreen.getContext('2d')!;
  ctx2d.fillStyle = '#fff';
  ctx2d.fillRect(0, 0, IW, IH);
  ctx2d.drawImage(img, 0, 0);

  const px  = ctx2d.getImageData(0, 0, IW, IH).data;
  const raw: { x: number; y: number }[] = [];

  const SAMPLE_STEP = 2;
  for (let py = 0; py < IH; py += SAMPLE_STEP) {
    for (let qx = 0; qx < IW; qx += SAMPLE_STEP) {
      const i    = (py * IW + qx) * 4;
      const luma = 0.299 * px[i] + 0.587 * px[i + 1] + 0.114 * px[i + 2];
      if (luma < 85) raw.push({ x: qx / IW - 0.5, y: 0.5 - py / IH });
    }
  }

  const MAX    = 6000;
  const stride = raw.length > MAX ? Math.floor(raw.length / MAX) : 1;
  const sampled = raw.filter((_, i) => i % stride === 0).slice(0, MAX);
  const N = sampled.length;

  const viewH    = 2 * CAM_Z * Math.tan((FOV / 2) * (Math.PI / 180));
  const imgAspect = IW / IH;
  let displayH   = viewH * 0.80;
  let displayW   = displayH * imgAspect;
  const viewW    = viewH * (innerWidth / innerHeight);
  if (displayW > viewW * 0.85) { displayW = viewW * 0.85; displayH = displayW / imgAspect; }

  const posArr        = new Float32Array(N * 3);
  const imgPos        = new Float32Array(N * 3);
  const startPos      = new Float32Array(N * 3);
  const delayArr      = new Float32Array(N);
  const angleArr      = new Float32Array(N);
  const radiusArr     = new Float32Array(N);
  const orbitDelayArr = new Float32Array(N);
  const spinMultArr   = new Float32Array(N);

  for (let i = 0; i < N; i++) {
    imgPos[i * 3 + 0] = sampled[i].x * displayW;
    imgPos[i * 3 + 1] = sampled[i].y * displayH;
    imgPos[i * 3 + 2] = 0;

    const ix = imgPos[i * 3 + 0], iy = imgPos[i * 3 + 1];
    angleArr[i]      = Math.atan2(iy, ix);
    radiusArr[i]     = Math.sqrt(ix * ix + iy * iy);
    orbitDelayArr[i] = Math.random() * 0.15;
    spinMultArr[i]   = 0.8 + Math.random() * 0.4;

    const angle = Math.random() * Math.PI * 2;
    const dist  = (1.4 + Math.random() * 0.8) * Math.max(viewH, viewW) * 0.65;
    startPos[i * 3 + 0] = Math.cos(angle) * dist;
    startPos[i * 3 + 1] = Math.sin(angle) * dist;
    startPos[i * 3 + 2] = (Math.random() - 0.5) * 1400;

    delayArr[i] = Math.random() * 0.10;
  }

  const geometry = new THREE.BufferGeometry();
  const posAttr  = new THREE.BufferAttribute(posArr, 3);
  posAttr.setUsage(THREE.DynamicDrawUsage);
  geometry.setAttribute('position', posAttr);

  const material = new THREE.PointsMaterial({
    color: 0xffffff,
    size: 2.0,
    sizeAttenuation: false,
    transparent: true,
    opacity: 1.0,
  });
  scene.add(new THREE.Points(geometry, material));

  // --- Wheel / swipe scroll ---
  const SENS = 1 / (innerHeight * 3.5);

  window.addEventListener('wheel', (e) => {
    e.preventDefault();
    scrollTarget = Math.max(0, Math.min(1, scrollTarget + e.deltaY * SENS));
  }, { passive: false });

  let touchY = 0;
  window.addEventListener('touchstart', (e) => {
    if (sliderActive) return;
    touchY = e.touches[0].clientY;
  }, { passive: true });
  window.addEventListener('touchmove', (e) => {
    if (sliderActive) return;
    e.preventDefault();
    const dy = touchY - e.touches[0].clientY;
    touchY = e.touches[0].clientY;
    scrollTarget = Math.max(0, Math.min(1, scrollTarget + dy * SENS * 2.5));
  }, { passive: false });

  // --- Easing ---
  function easeOut3(t: number)    { return 1 - Math.pow(1 - t, 3); }
  function easeIn3(t: number)     { return t * t * t; }
  function smoothstep(t: number)  { return t * t * (3 - 2 * t); }
  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function clamp01(t: number) { return Math.max(0, Math.min(1, t)); }

  const P1 = 0.52;
  const P2 = 0.70;

  // --- Knot position update ---
  function updateKnot() {
    knot.style.top = (scrollProg * 100).toFixed(2) + '%';
  }

  function animate() {
    requestAnimationFrame(animate);

    scrollProg += (scrollTarget - scrollProg) * 0.075;

    // Scroll hint: fade out once scrolling begins
    const hintOpacity = scrollProg < 0.03
      ? 1
      : Math.max(0, 1 - (scrollProg - 0.03) / 0.05);
    hint.style.opacity = String(hintOpacity);

    updateKnot();

    const pos = posAttr.array as Float32Array;
    for (let i = 0; i < N; i++) {
      const ix = imgPos[i * 3 + 0], iy = imgPos[i * 3 + 1];
      const sx = startPos[i * 3 + 0], sy = startPos[i * 3 + 1], sz = startPos[i * 3 + 2];
      const delay = delayArr[i];

      // Phase 1: scatter → image
      const raw1 = clamp01((scrollProg - delay) / (P1 - delay * 0.6));
      const t1   = easeOut3(raw1);
      const p1x  = lerp(sx, ix, t1), p1y = lerp(sy, iy, t1), p1z = lerp(sz, 0, t1);

      // Phase 3: orbit + gravity — both spin and collapse ease in from rest
      const SPIN   = Math.PI * 5;
      const oStart = P2 + orbitDelayArr[i] * (1 - P2) * 0.3;
      const t3raw  = clamp01((scrollProg - oStart) / (1 - oStart));
      const t3spin = easeIn3(t3raw);  // angle accelerates from 0
      const t3pull = easeIn3(t3raw);  // radius collapse also accelerates
      const oa     = angleArr[i] + SPIN * spinMultArr[i] * t3spin;
      const or_    = radiusArr[i] * (1 - t3pull);
      const p3x    = or_ * Math.cos(oa), p3y = or_ * Math.sin(oa);

      // Blend 1→2 (image) around P1, blend 2→3 (orbit) around P2
      const BLEN = 0.07;
      const b1 = smoothstep(clamp01((scrollProg - (P1 - BLEN)) / (BLEN * 2)));
      const b2 = smoothstep(clamp01((scrollProg - (P2 - BLEN)) / (BLEN * 2)));

      const x12 = lerp(p1x, ix, b1), y12 = lerp(p1y, iy, b1), z12 = lerp(p1z, 0, b1);
      const x   = lerp(x12, p3x, b2);
      const y   = lerp(y12, p3y, b2);
      const z   = lerp(z12, 0,   b2);

      pos[i * 3 + 0] = x;
      pos[i * 3 + 1] = y;
      pos[i * 3 + 2] = z;
    }

    posAttr.needsUpdate = true;
    renderer.render(scene, camera);
  }

  animate();
}

main();
</script>
