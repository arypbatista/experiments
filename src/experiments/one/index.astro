---
import src from "./creation-of-adam.png";
const { src: imageSrc, width: imageW, height: imageH } = src;
---

<canvas
  id="canvas"
  style="display:block;width:100vw;height:100vh;"
  data-src={imageSrc}
  data-w={imageW}
  data-h={imageH}
></canvas>

<script>
  import * as THREE from 'three';

  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;
    const imageSrc = canvas.dataset.src!;
    const imageW = Number(canvas.dataset.w);
    const imageH = Number(canvas.dataset.h);

    // ── Spring ──────────────────────────────────────────────────────────────
    let targetX = -9999, targetY = -9999;
    let springX = -9999, springY = -9999;
    let velX = 0, velY = 0;
    const STIFFNESS = 0.04, DAMPING = 0.85;

    window.addEventListener('mousemove', (e) => {
      if (targetX === -9999) { springX = e.clientX; springY = e.clientY; }
      targetX = e.clientX; targetY = e.clientY;
    });
    window.addEventListener('mouseleave', () => { targetX = -9999; targetY = -9999; });

    function tickSpring() {
      const tx = targetX === -9999 ? -9999 : targetX;
      const ty = targetY === -9999 ? -9999 : targetY;
      velX += (tx - springX) * STIFFNESS;
      velY += (ty - springY) * STIFFNESS;
      velX *= DAMPING; velY *= DAMPING;
      springX += velX; springY += velY;
    }

    // ── Image sampling ───────────────────────────────────────────────────────
    const img = new Image();
    img.onload = () => start(img);
    img.src = imageSrc;

    function sampleImage(img: HTMLImageElement, spacing: number) {
      const offscreen = document.createElement('canvas');
      offscreen.width = img.width; offscreen.height = img.height;
      const ctx = offscreen.getContext('2d')!;
      ctx.fillStyle = '#fff';
      ctx.fillRect(0, 0, img.width, img.height);
      ctx.drawImage(img, 0, 0);
      const px = ctx.getImageData(0, 0, img.width, img.height).data;

      const cols = Math.floor(img.width  / spacing);
      const rows = Math.floor(img.height / spacing);
      const samples: number[] = [];

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const sx = Math.floor((c + 0.5) * spacing);
          const sy = Math.floor((r + 0.5) * spacing);
          const i  = (sy * img.width + sx) * 4;
          const luma = (px[i] * 0.299 + px[i+1] * 0.587 + px[i+2] * 0.114) / 255;
          const brightness = 1 - luma;
          if (brightness >= 0.4) {
            samples.push((c / cols) - 0.5, -((r / rows) - 0.5), brightness);
          }
        }
      }
      return new Float32Array(samples);
    }

    // ── Three.js point cloud ─────────────────────────────────────────────────
    function start(img: HTMLImageElement) {
      const SPACING       = 7;
      const BUBBLE_RADIUS = 60;
      const BUBBLE_Z      = 2.5;
      const BUBBLE_SPREAD = 0.15;

      const samples = sampleImage(img, SPACING);
      const count   = samples.length / 3;

      const positions      = new Float32Array(count * 3);
      const baseBrightness = new Float32Array(count);

      const aspect = imageW / imageH;
      const planeH = 2.0;
      const planeW = planeH * aspect;

      for (let i = 0; i < count; i++) {
        positions[i * 3]     = samples[i * 3]     * planeW;
        positions[i * 3 + 1] = samples[i * 3 + 1] * planeH;
        positions[i * 3 + 2] = 0;
        baseBrightness[i]    = samples[i * 3 + 2];
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute('position',   new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('brightness', new THREE.BufferAttribute(baseBrightness, 1));

      const material = new THREE.ShaderMaterial({
        uniforms: {
          uTime:         { value: 0 },
          uMouse:        { value: new THREE.Vector2(-9999, -9999) },
          uBubbleRadius: { value: BUBBLE_RADIUS },
          uBubbleZ:      { value: BUBBLE_Z },
          uBubbleSpread: { value: BUBBLE_SPREAD },
          uResolution:   { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
        },
        vertexShader: `
          attribute float brightness;
          uniform float uTime;
          uniform vec2  uMouse;
          uniform float uBubbleRadius;
          uniform float uBubbleZ;
          uniform float uBubbleSpread;
          uniform vec2  uResolution;

          varying float vBubble;

          void main() {
            vec4 clip   = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            vec2 ndc    = clip.xy / clip.w;
            vec2 screen = (ndc * 0.5 + 0.5) * uResolution;
            vec2 mouseGL = vec2(uMouse.x, uResolution.y - uMouse.y);

            float dist   = length(screen - mouseGL);
            float bubble = uMouse.x < -100.0 ? 0.0
              : exp(-dist * dist / (2.0 * uBubbleRadius * uBubbleRadius));
            vBubble = bubble;

            // Spread radially away from bubble center in world XY
            vec2 bubbleWorld = vec2(
              (uMouse.x / uResolution.x - 0.5),
              -(uMouse.y / uResolution.y - 0.5)
            ) * vec2(uResolution.x / uResolution.y, 1.0) * 3.0;
            vec2 toEdge   = position.xy - bubbleWorld;
            float edgeLen = length(toEdge);
            vec2 spreadDir = edgeLen > 0.0001 ? toEdge / edgeLen : vec2(0.0);
            vec3 spreadPos = vec3(position.xy + spreadDir * bubble * uBubbleSpread, position.z);

            // Move toward camera along view-space ray (no perspective drift)
            vec4 viewPos   = modelViewMatrix * vec4(spreadPos, 1.0);
            vec3 toCamera  = normalize(-viewPos.xyz);
            vec3 liftedView = viewPos.xyz + toCamera * bubble * uBubbleZ;

            float pulse = 1.0 + 0.04 * sin(uTime * 1.2);
            gl_PointSize = brightness * 6.0 * pulse * (1.0 + bubble * 0.3);
            gl_Position  = projectionMatrix * vec4(liftedView, 1.0);
          }
        `,
        fragmentShader: `
          varying float vBubble;

          void main() {
            vec2 uv = gl_PointCoord - 0.5;
            if (length(uv) > 0.5) discard;
            float alpha = smoothstep(0.5, 0.42, length(uv));
            gl_FragColor = vec4(alpha, alpha, alpha, 1.0);
          }
        `,
      });

      const scene  = new THREE.Scene();
      scene.background = new THREE.Color(0x000000);
      scene.add(new THREE.Points(geometry, material));

      const camera = new THREE.PerspectiveCamera(40, window.innerWidth / window.innerHeight, 0.1, 1000);
      camera.position.z = 4.05;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      renderer.setSize(window.innerWidth, window.innerHeight);

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        material.uniforms.uResolution.value.set(window.innerWidth, window.innerHeight);
      });

      (function draw(t: number) {
        tickSpring();
        material.uniforms.uTime.value  = t * 0.001;
        material.uniforms.uMouse.value.set(springX, springY);
        renderer.render(scene, camera);
        requestAnimationFrame(draw);
      })(0);
    }
  });
</script>
