    ${p.map(c=>`<div style="height:38px;background:${c};display:flex;align-items:center;padding:0 10px;">
      <span style="font-family:monospace;font-size:10px;color:rgba(0,0,0,0.55);letter-spacing:.05em;">${c}</span>
