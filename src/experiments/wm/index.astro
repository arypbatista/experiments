    if (vp) vp.textContent = `${window.innerWidth}×${window.innerHeight}`;
    if (wc) wc.textContent = String([...wins.values()].filter(w => !w.closed).length);
    if (cm) cm.textContent = ms.canvasMode;
    if (st) st.textContent = ms.sticky  ? 'on' : 'off';
    if (co) co.textContent = ms.contain ? 'on' : 'off';
    setTimeout(updateInfo, 400);
  }
  setTimeout(updateInfo, 200);
}

// ─── Boot ─────────────────────────────────────────────────────────────────────

applyCanvasMode();
spawnExamples();
requestAnimationFrame(tick);
</script>
