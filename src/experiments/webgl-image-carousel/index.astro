---
---

<div id="root" style="position:relative;width:100vw;height:100vh;overflow:hidden;background:#080808;">
  <canvas id="canvas" style="display:block;width:100%;height:100%;"></canvas>

  <!-- Edge vignette to fade images at left/right -->
  <div style="
    position:absolute;inset:0;pointer-events:none;z-index:5;
    background:linear-gradient(to right,
      rgba(8,8,8,0.85) 0%,
      transparent 12%,
      transparent 88%,
      rgba(8,8,8,0.85) 100%);
  "></div>

  <!-- Left arrow -->
  <button id="btn-left" aria-label="Previous" style="
    position:absolute;left:20px;top:50%;transform:translateY(-50%);
    width:48px;height:48px;border-radius:50%;
    background:rgba(0,0,0,0.55);border:1px solid rgba(255,255,255,0.15);
    color:#aaa;font-size:22px;cursor:pointer;z-index:10;
    display:flex;align-items:center;justify-content:center;
    font-family:monospace;padding:0;line-height:1;
    transition:color .18s,background .18s;
  ">‹</button>

  <!-- Right arrow -->
  <button id="btn-right" aria-label="Next" style="
    position:absolute;right:20px;top:50%;transform:translateY(-50%);
    width:48px;height:48px;border-radius:50%;
    background:rgba(0,0,0,0.55);border:1px solid rgba(255,255,255,0.15);
    color:#aaa;font-size:22px;cursor:pointer;z-index:10;
    display:flex;align-items:center;justify-content:center;
    font-family:monospace;padding:0;line-height:1;
    transition:color .18s,background .18s;
  ">›</button>

  <!-- Resume autoplay button (manual mode only) -->
  <button id="btn-auto" aria-label="Resume autoplay" style="
    display:none;
    position:absolute;bottom:24px;right:24px;
    background:rgba(0,0,0,0.6);border:1px solid rgba(255,255,255,0.14);
    color:#888;font-size:11px;padding:7px 16px;cursor:pointer;
    border-radius:4px;font-family:monospace;z-index:10;letter-spacing:0.08em;
    transition:color .18s;
  ">▶ autoplay</button>
</div>

<!-- Popup backdrop -->
<div id="popup-backdrop" style="
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,0.75);z-index:10000;
"></div>

<!-- Popup -->
<div id="popup" style="
  display:none;position:fixed;top:50%;left:50%;
  transform:translate(-50%,-50%);z-index:10001;
  width:min(460px,88vw);
  background:#131313;border:1px solid rgba(255,255,255,0.1);
  border-radius:12px;overflow:hidden;
  box-shadow:0 24px 64px rgba(0,0,0,0.7);
">
  <div id="popup-swatch" style="height:4px;"></div>
  <div style="padding:24px 24px 22px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;">
      <div>
        <h3 id="popup-title" style="
          margin:0;color:#eee;font-size:16px;
          font-family:monospace;font-weight:600;letter-spacing:.02em;
        "></h3>
        <span id="popup-date" style="
          display:block;margin-top:5px;
          color:#444;font-size:11px;font-family:monospace;letter-spacing:.06em;
        "></span>
      </div>
      <button id="popup-close" style="
        background:none;border:none;color:#444;font-size:22px;
        cursor:pointer;padding:0;line-height:1;margin-left:16px;
        flex-shrink:0;transition:color .15s;
      ">✕</button>
    </div>
    <p id="popup-desc" style="
      margin:0;color:#6a6a6a;font-size:13px;
      line-height:1.8;font-family:monospace;
    "></p>
  </div>
</div>

<script>
  import * as THREE from 'three';

  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;

    // ── Constants ──────────────────────────────────────────────────────────────
    const N        = 8;
    const IW       = 300;          // image plane width (world px)
    const IH       = 200;          // image plane height (world px)
    const GAP      = 44;
    const STRIDE   = IW + GAP;    // 344
    const TOTAL_W  = N * STRIDE;  // 2752
    const CORNER_R = 14;          // corner radius (world px)
    const AUTO_SPD = 0.85;        // px/frame in auto mode
    const SPRING_K = 0.07;
    const SPRING_D = 0.84;
    const HOVER_S  = 0.10;        // scale factor on hover
    const BLUR_K   = 0.042;       // motion blur per px/frame of velocity
    const BLUR_MAX = 0.14;        // max UV units of blur

    // ── Image metadata ─────────────────────────────────────────────────────────
    const HUES = [12, 47, 95, 140, 185, 228, 270, 315];
    const INFO = [
      { title: 'Gradient Study I',  desc: 'An exploration of warm gradients and color harmony. Light and form create a continuous sense of depth.',       date: 'Apr 2026' },
      { title: 'Pattern II',        desc: 'Geometric repetition through complementary hues, loosely inspired by mid-century textile design.',              date: 'Mar 2026' },
      { title: 'Landscape III',     desc: 'A procedural landscape interpretation. Layers of color evoke the horizon at dusk, shifting and settling.',      date: 'Feb 2026' },
      { title: 'Form IV',           desc: 'Abstract shapes in slow motion. The boundary between figure and ground dissolves into a unified field.',        date: 'Jan 2026' },
      { title: 'Spectrum V',        desc: 'A sweep across the visible spectrum. Light decomposes into its constituent wavelengths and folds back.',        date: 'Dec 2025' },
      { title: 'Depth VI',          desc: 'Simultaneous contrast creates the illusion of three-dimensional space projected onto a flat surface.',           date: 'Nov 2025' },
      { title: 'Rhythm VII',        desc: 'Regular intervals of color and void. Visual rhythm as an analogue for musical phrasing and breath.',            date: 'Oct 2025' },
      { title: 'Echo VIII',         desc: 'Repetition with subtle variation. Each iteration differs just enough from the one before it to feel alive.',    date: 'Sep 2025' },
    ];

    // ── Renderer ───────────────────────────────────────────────────────────────
    const W = () => window.innerWidth;
    const H = () => window.innerHeight;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setSize(W(), H());
    renderer.setClearColor(0x080808);

    const camera = new THREE.OrthographicCamera(-W()/2, W()/2, H()/2, -H()/2, 0.1, 1000);
    camera.position.z = 10;

    const scene = new THREE.Scene();

    // ── Procedural placeholder textures ───────────────────────────────────────
    function makeTex(idx: number): THREE.CanvasTexture {
      const cw = IW * 2, ch = IH * 2;
      const c = document.createElement('canvas');
      c.width = cw; c.height = ch;
      const ctx = c.getContext('2d')!;
      const h = HUES[idx];

      // Background gradient
      const bg = ctx.createLinearGradient(0, 0, cw, ch);
      bg.addColorStop(0, `hsl(${h},48%,12%)`);
      bg.addColorStop(1, `hsl(${(h + 90) % 360},54%,7%)`);
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, cw, ch);

      // Scattered circles (deterministic from idx)
      for (let j = 0; j < 9; j++) {
        const cx = ((idx * 137.508 + j * 73.3) % 1.0) * cw;
        const cy = ((idx * 89.2   + j * 59.7) % 1.0) * ch;
        const r  = 18 + ((idx * 31 + j * 47) % 110);
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${(h + j * 37) % 360},75%,55%,0.10)`;
        ctx.fill();
      }

      // Radial glow at center
      const gw = ctx.createRadialGradient(cw/2, ch/2, 0, cw/2, ch/2, cw * 0.55);
      gw.addColorStop(0, `hsla(${h},65%,55%,0.22)`);
      gw.addColorStop(1, `hsla(${h},65%,55%,0)`);
      ctx.fillStyle = gw;
      ctx.fillRect(0, 0, cw, ch);

      // Large ghosted index number
      ctx.font = `bold ${Math.round(ch * 0.44)}px monospace`;
      ctx.fillStyle = `hsla(${h},44%,64%,0.11)`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(String(idx + 1), cw / 2, ch / 2);

      return new THREE.CanvasTexture(c);
    }

    // ── Shaders ────────────────────────────────────────────────────────────────
    const vertSrc = /* glsl */`
      varying vec2 vUv;
      void main() {
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    const fragSrc = /* glsl */`
      uniform sampler2D uTex;
      uniform float     uBlur;
      uniform float     uHov;
      uniform vec2      uSz;
      uniform float     uR;
      varying vec2      vUv;

      const int SAMPLES = 10;

      void main() {
        // Rounded-rectangle mask via pixel-space SDF
        vec2  px   = vUv * uSz;
        vec2  q    = abs(px - uSz * 0.5) - (uSz * 0.5 - uR);
        float d    = length(max(q, 0.0));
        float mask = 1.0 - smoothstep(uR - 1.5, uR + 0.5, d);
        if (mask < 0.01) discard;

        // Horizontal motion blur — sample along scroll direction
        vec4 col = vec4(0.0);
        for (int i = 0; i < SAMPLES; i++) {
          float t  = float(i) / float(SAMPLES - 1) - 0.5;
          float sx = clamp(vUv.x + t * uBlur, 0.0, 1.0);
          col += texture2D(uTex, vec2(sx, vUv.y));
        }
        col /= float(SAMPLES);

        // Hover: subtle brightness boost
        col.rgb *= 1.0 + uHov * 0.30;

        gl_FragColor = vec4(col.rgb, mask);
      }
    `;

    // ── Meshes ─────────────────────────────────────────────────────────────────
    const geo   = new THREE.PlaneGeometry(IW, IH);
    const meshes: THREE.Mesh[]          = [];
    const mats:   THREE.ShaderMaterial[] = [];

    for (let i = 0; i < N; i++) {
      const mat = new THREE.ShaderMaterial({
        uniforms: {
          uTex:  { value: makeTex(i) },
          uBlur: { value: 0 },
          uHov:  { value: 0 },
          uSz:   { value: new THREE.Vector2(IW, IH) },
          uR:    { value: CORNER_R },
        },
        vertexShader:   vertSrc,
        fragmentShader: fragSrc,
        transparent:    true,
      });
      mats.push(mat);
      const mesh = new THREE.Mesh(geo, mat);
      scene.add(mesh);
      meshes.push(mesh);
    }

    // ── Scroll state ───────────────────────────────────────────────────────────
    let isAuto    = true;
    let offset    = 0;   // current rendered scroll position (unbounded px)
    let targetOff = 0;   // spring target (unbounded px)
    let offVel    = 0;   // spring velocity

    // ── Hover spring state ─────────────────────────────────────────────────────
    const hovVal = new Array(N).fill(0);
    const hovVel = new Array(N).fill(0);

    // ── Controls ───────────────────────────────────────────────────────────────
    const btnLeft  = document.getElementById('btn-left')!  as HTMLButtonElement;
    const btnRight = document.getElementById('btn-right')! as HTMLButtonElement;
    const btnAuto  = document.getElementById('btn-auto')!  as HTMLButtonElement;

    function enterManual(): void {
      if (!isAuto) return;
      isAuto    = false;
      targetOff = Math.round(offset / STRIDE) * STRIDE;
      btnAuto.style.display = 'block';
    }

    function goDir(dir: number): void {
      enterManual();
      targetOff = Math.round(targetOff / STRIDE) * STRIDE + dir * STRIDE;
    }

    btnLeft.addEventListener('click',  () => goDir(-1));
    btnRight.addEventListener('click', () => goDir(1));
    btnAuto.addEventListener('click', () => {
      isAuto    = true;
      targetOff = offset; // continue smoothly from current position
      btnAuto.style.display = 'none';
    });

    // Arrow hover styling
    [btnLeft, btnRight].forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        btn.style.color = '#fff';
        btn.style.background = 'rgba(28,28,28,0.8)';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.color = '#aaa';
        btn.style.background = 'rgba(0,0,0,0.55)';
      });
    });
    btnAuto.addEventListener('mouseenter', () => { btnAuto.style.color = '#fff'; });
    btnAuto.addEventListener('mouseleave', () => { btnAuto.style.color = '#888'; });

    // ── Pointer tracking ───────────────────────────────────────────────────────
    let mouseX  = -9999, mouseY = -9999;
    let clickSX = 0, clickSY = 0;

    window.addEventListener('mousemove',  (e) => { mouseX = e.clientX; mouseY = e.clientY; });
    window.addEventListener('mouseleave', ()  => { mouseX = -9999; mouseY = -9999; });
    canvas.addEventListener('mousedown',  (e) => { clickSX = e.clientX; clickSY = e.clientY; });
    canvas.addEventListener('click', (e) => {
      if (Math.hypot(e.clientX - clickSX, e.clientY - clickSY) > 8) return;
      hitTest(e.clientX, e.clientY);
    });

    // ── Touch ──────────────────────────────────────────────────────────────────
    let touchSX = 0, touchSY = 0;
    window.addEventListener('touchstart', (e) => {
      touchSX = e.touches[0].clientX;
      touchSY = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchend', (e) => {
      const cx = e.changedTouches[0].clientX;
      const cy = e.changedTouches[0].clientY;
      const dx = cx - touchSX;
      const dy = cy - touchSY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        goDir(dx < 0 ? 1 : -1);
      } else if (Math.hypot(dx, dy) < 12) {
        hitTest(cx, cy);
      }
    }, { passive: true });

    // ── Scroll wheel ───────────────────────────────────────────────────────────
    let wheelAcc = 0;
    window.addEventListener('wheel', (e) => {
      e.preventDefault();
      wheelAcc += e.deltaY;
      if (Math.abs(wheelAcc) >= 80) {
        goDir(wheelAcc > 0 ? 1 : -1);
        wheelAcc = 0;
      }
    }, { passive: false });

    // ── Popup ──────────────────────────────────────────────────────────────────
    let popupOpen = false;
    const backdrop = document.getElementById('popup-backdrop')!;
    const popup    = document.getElementById('popup')!;
    const pTitle   = document.getElementById('popup-title')!;
    const pDate    = document.getElementById('popup-date')!;
    const pDesc    = document.getElementById('popup-desc')!;
    const pSwatch  = document.getElementById('popup-swatch')!;

    function showPopup(i: number): void {
      const d = INFO[i];
      pTitle.textContent  = d.title;
      pDate.textContent   = d.date;
      pDesc.textContent   = d.desc;
      pSwatch.style.background = `hsl(${HUES[i]},65%,40%)`;
      backdrop.style.display = 'block';
      popup.style.display    = 'block';
      popupOpen = true;
    }

    function hidePopup(): void {
      backdrop.style.display = 'none';
      popup.style.display    = 'none';
      popupOpen = false;
    }

    document.getElementById('popup-close')!.addEventListener('click', hidePopup);
    backdrop.addEventListener('click', hidePopup);

    document.getElementById('popup-close')!.addEventListener('mouseenter', (e) => {
      (e.target as HTMLElement).style.color = '#aaa';
    });
    document.getElementById('popup-close')!.addEventListener('mouseleave', (e) => {
      (e.target as HTMLElement).style.color = '#444';
    });

    // ── Hit testing ────────────────────────────────────────────────────────────
    function hitTest(cx: number, cy: number): void {
      if (popupOpen) { hidePopup(); return; }
      const wx = cx - W() / 2;
      const wy = -(cy - H() / 2);
      for (let i = 0; i < N; i++) {
        const s  = meshes[i].scale.x;
        const mx = meshes[i].position.x;
        const my = meshes[i].position.y;
        if (Math.abs(wx - mx) < (IW / 2) * s &&
            Math.abs(wy - my) < (IH / 2) * s) {
          showPopup(i);
          return;
        }
      }
    }

    // ── Wrapped X position for infinite loop ───────────────────────────────────
    function wrappedX(i: number, wOff: number): number {
      let x = i * STRIDE - wOff;
      x = ((x + TOTAL_W / 2) % TOTAL_W + TOTAL_W) % TOTAL_W - TOTAL_W / 2;
      return x;
    }

    // ── Resize ─────────────────────────────────────────────────────────────────
    window.addEventListener('resize', () => {
      camera.left   = -W()/2; camera.right  =  W()/2;
      camera.top    =  H()/2; camera.bottom = -H()/2;
      camera.updateProjectionMatrix();
      renderer.setSize(W(), H());
    });

    // ── Render loop ────────────────────────────────────────────────────────────
    function frame(): void {
      requestAnimationFrame(frame);

      // Advance spring target
      if (isAuto) targetOff += AUTO_SPD;

      // Spring integration
      offVel += (targetOff - offset) * SPRING_K;
      offVel *= SPRING_D;
      offset += offVel;

      const blur = Math.min(Math.abs(offVel) * BLUR_K, BLUR_MAX);
      const wOff = ((offset % TOTAL_W) + TOTAL_W) % TOTAL_W;

      // Hover detection (mouse in world space)
      const wx = mouseX - W() / 2;
      const wy = -(mouseY - H() / 2);
      let hovIdx = -1;

      for (let i = 0; i < N; i++) {
        const x = wrappedX(i, wOff);
        meshes[i].position.x = x;

        if (mouseX !== -9999 &&
            Math.abs(wx - x) < IW / 2 &&
            Math.abs(wy - meshes[i].position.y) < IH / 2) {
          hovIdx = i;
        }
      }

      canvas.style.cursor = hovIdx >= 0 ? 'pointer' : 'default';

      // Update hover springs + shader uniforms
      for (let i = 0; i < N; i++) {
        hovVel[i] += ((i === hovIdx ? 1 : 0) - hovVal[i]) * 0.12;
        hovVel[i] *= 0.72;
        hovVal[i]  = Math.max(0, Math.min(1, hovVal[i] + hovVel[i]));

        meshes[i].scale.setScalar(1 + hovVal[i] * HOVER_S);
        mats[i].uniforms.uBlur.value = blur * (1 - hovVal[i] * 0.6);
        mats[i].uniforms.uHov.value  = hovVal[i];
      }

      renderer.render(scene, camera);
    }

    frame();
  });
</script>
